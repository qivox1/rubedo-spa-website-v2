{
  "ci": {
    "collect": {
      "staticDistDir": "./dist",
      "url": [
        "http://localhost/",
        "http://localhost/philosophie/",
        "http://localhost/dna-skin-intelligence/",
        "http://localhost/kryo-vital/",
        "http://localhost/inner-source/",
        "http://localhost/ueber-monica/",
        "http://localhost/termin-buchen/"
      ],
      "settings": {
        "preset": "desktop"
      }
    },
    "assert": {
      "assertions": {
        "categories:performance": ["error", { "minScore": 0.95 }],
        "categories:accessibility": ["error", { "minScore": 1.0 }],
        "categories:best-practices": ["error", { "minScore": 0.95 }],
        "categories:seo": ["error", { "minScore": 1.0 }],
        "uses-text-compression": "off",
        "is-on-https": "off",
        "redirects-http": "off"
      }
    }
  }
}
