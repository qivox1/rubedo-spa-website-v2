---
import { site } from '@/lib/site';

const { ga4, gtm } = site.tracking;
---

{/* Consent-Mode + Tag-Loader — render-non-blocking.
    Setup-Skript läuft sofort, GTM-Iframe + GA4-Skript erst nach
    `requestIdleCallback` (oder als Fallback nach 1500ms), damit
    LCP/FCP nicht vom Tracking ausgebremst werden. */}
{(gtm || ga4) && (
  <script is:inline define:vars={{ gtm, ga4 }}>
window.dataLayer = window.dataLayer || [];
function gtag(){window.dataLayer.push(arguments);}
gtag('consent', 'default', {
  ad_storage: 'denied',
  analytics_storage: 'denied',
  ad_user_data: 'denied',
  ad_personalization: 'denied',
  functionality_storage: 'granted',
  security_storage: 'granted',
  wait_for_update: 500,
});
gtag('set', 'ads_data_redaction', true);

(function(){
  var loadTrackers = function() {
    if (window.__rb_trackers_loaded) return;
    window.__rb_trackers_loaded = true;
    if (gtm) {
      var f = document.getElementsByTagName('script')[0];
      var j = document.createElement('script');
      j.async = true;
      j.src = 'https://www.googletagmanager.com/gtm.js?id=' + gtm;
      f.parentNode.insertBefore(j, f);
      window.dataLayer.push({'gtm.start': new Date().getTime(), event: 'gtm.js'});
    }
    if (ga4) {
      var g = document.createElement('script');
      g.async = true;
      g.src = 'https://www.googletagmanager.com/gtag/js?id=' + ga4;
      document.head.appendChild(g);
      gtag('js', new Date());
      gtag('config', ga4, { anonymize_ip: true });
    }
  };
  var idle = window.requestIdleCallback || function(cb){return setTimeout(cb, 1);};
  var triggered = false;
  var trigger = function(){ if (triggered) return; triggered = true; loadTrackers(); };
  ['scroll','click','keydown','touchstart','mousemove'].forEach(function(ev){
    window.addEventListener(ev, trigger, {once: true, passive: true});
  });
  if (document.readyState === 'complete') {
    idle(trigger, {timeout: 3000});
  } else {
    window.addEventListener('load', function(){ idle(trigger, {timeout: 3000}); });
  }
})();
  </script>
)}
