---
/**
 * MagazinTeaser — kuratiert verlinkbare Magazin-Artikel
 * auf Hub-, Service- und Behandlungsseiten.
 *
 * Filtert die Magazin-Collection dynamisch nach
 *   • Tag-Schnittmenge (mind. ein Artikel-Tag muss in `tags` enthalten sein)
 *   • Kategorie (exact match, optional)
 * Sortiert nach pubDate DESC und limitiert auf `limit` (default 3).
 *
 * Rendert nichts, wenn nach Filterung 0 Artikel übrig bleiben.
 *
 * Damit ist diese Komponente das Hub-and-Spoke-Vehikel: jede Säulen-, Service-
 * oder Behandlungsseite verlinkt automatisch auf passende Magazin-Beiträge,
 * sobald diese veröffentlicht werden — ohne dass die Hub-Seiten gepflegt
 * werden müssen.
 */
import type { CollectionEntry } from 'astro:content';
import { getCollection } from 'astro:content';

interface Props {
  /** Tags, von denen mindestens einer im Artikel-Frontmatter vorkommen muss. */
  tags?: string[];
  /** Kategorie-Filter (exact). */
  category?: string;
  /** Slug des aktuellen Artikels — wird ausgeschlossen. */
  excludeSlug?: string;
  /** Maximale Anzahl Karten. Default 3. */
  limit?: number;
  /** Eyebrow-Text. Default „Aus dem Magazin". */
  eyebrow?: string;
  /** Headline. Default „Weiterlesen im Magazin". */
  heading?: string;
  /** Optional: Subtext direkt unter Heading. */
  intro?: string;
  /** Section-Variant: paper (Default) oder cream. */
  variant?: 'paper' | 'cream';
}

const {
  tags = [],
  category,
  excludeSlug,
  limit = 3,
  eyebrow = 'Aus dem Magazin',
  heading = 'Weiterlesen im Magazin',
  intro,
  variant = 'paper',
} = Astro.props;

const all = await getCollection('magazin', ({ data }) => !data.draft);

const filtered: CollectionEntry<'magazin'>[] = all
  .filter((a) => a.slug !== excludeSlug)
  .filter((a) => {
    if (category && a.data.category !== category) return false;
    if (tags.length > 0) {
      const hit = tags.some((t) => a.data.tags.includes(t));
      if (!hit) return false;
    }
    return true;
  })
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
  .slice(0, limit);

const fmtDate = (d: Date) =>
  new Intl.DateTimeFormat('de-DE', { day: 'numeric', month: 'long', year: 'numeric' }).format(d);

const variantClass = variant === 'cream' ? 'rb-mag-teaser--cream' : 'rb-mag-teaser--paper';
---

{filtered.length > 0 && (
  <section class={`rb-mag-teaser ${variantClass}`} aria-label={heading}>
    <div class="rb-wrap">
      <header class="rb-mag-teaser__head">
        <span class="rb-eyebrow">{eyebrow}</span>
        <h2 class="rb-mag-teaser__heading">{heading}</h2>
        {intro && <p class="rb-mag-teaser__intro">{intro}</p>}
      </header>

      <div class="rb-mag-teaser__grid">
        {filtered.map((entry) => (
          <a class="rb-mag-teaser__card" href={`/magazin/${entry.slug}/`}>
            <div class="rb-mag-teaser__photo" style={`background-image: url('${entry.data.heroImage}');`} aria-hidden="true">
              <span class="rb-mag-teaser__cat">{entry.data.category}</span>
            </div>
            <div class="rb-mag-teaser__body">
              <h3 class="rb-mag-teaser__title">{entry.data.title}</h3>
              <p class="rb-mag-teaser__excerpt">{entry.data.excerpt ?? entry.data.description}</p>
              <div class="rb-mag-teaser__meta">
                <time datetime={entry.data.pubDate.toISOString()}>{fmtDate(entry.data.pubDate)}</time>
                {entry.data.readingTime && (<><span aria-hidden="true">·</span><span>{entry.data.readingTime} Min. Lesezeit</span></>)}
              </div>
            </div>
          </a>
        ))}
      </div>

      <div class="rb-mag-teaser__more">
        <a href="/magazin/" class="rb-btn rb-btn--link">Alle Artikel im Magazin →</a>
      </div>
    </div>
  </section>
)}

<style>
  .rb-mag-teaser {
    padding: clamp(56px, 8vw, 96px) 0;
  }
  .rb-mag-teaser--paper { background: var(--rb-paper); }
  .rb-mag-teaser--cream { background: var(--rb-cream); }

  .rb-mag-teaser__head {
    max-width: 56ch;
    margin: 0 auto clamp(32px, 4vw, 48px);
    text-align: center;
  }
  .rb-mag-teaser__heading {
    font-family: var(--rb-font-display);
    font-weight: 400;
    font-size: clamp(28px, 3vw, 40px);
    line-height: 1.15;
    margin: 8px 0 0;
    color: var(--rb-ink-900);
    text-wrap: balance;
  }
  .rb-mag-teaser__intro {
    font-family: var(--rb-font-body);
    color: var(--rb-ink-500);
    margin: 16px auto 0;
    max-width: 56ch;
    text-wrap: balance;
  }

  .rb-mag-teaser__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 24px;
  }
  @media (min-width: 720px) { .rb-mag-teaser__grid { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 1024px) { .rb-mag-teaser__grid { grid-template-columns: repeat(3, 1fr); } }

  .rb-mag-teaser__card {
    display: flex;
    flex-direction: column;
    background: transparent;
    text-decoration: none;
    color: inherit;
    border-radius: var(--rb-radius-md);
    overflow: hidden;
    transition: transform var(--rb-dur-2) var(--rb-ease);
  }
  .rb-mag-teaser__card:hover { transform: translateY(-4px); }

  .rb-mag-teaser__photo {
    position: relative;
    aspect-ratio: 3 / 2;
    background-size: cover;
    background-position: center;
    border-radius: var(--rb-radius-md);
    overflow: hidden;
  }
  .rb-mag-teaser__cat {
    position: absolute;
    top: 12px; left: 12px;
    font-family: var(--rb-font-body);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: var(--rb-tracking-widest);
    text-transform: uppercase;
    color: var(--rb-paper);
    background: rgba(28, 18, 18, 0.55);
    padding: 6px 10px;
    border-radius: var(--rb-radius-pill);
    backdrop-filter: blur(6px);
  }

  .rb-mag-teaser__body { padding: 18px 4px 0; }

  .rb-mag-teaser__title {
    font-family: var(--rb-font-display);
    font-weight: 400;
    font-size: clamp(18px, 1.6vw, 22px);
    line-height: 1.25;
    margin: 0 0 10px;
    color: var(--rb-ink-900);
    text-wrap: balance;
    transition: color var(--rb-dur-1) var(--rb-ease);
  }
  .rb-mag-teaser__card:hover .rb-mag-teaser__title { color: var(--rb-gold-700); }

  .rb-mag-teaser__excerpt {
    font-family: var(--rb-font-body);
    font-size: 14px;
    color: var(--rb-ink-500);
    line-height: 1.55;
    margin: 0 0 12px;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .rb-mag-teaser__meta {
    display: flex; flex-wrap: wrap;
    gap: 8px;
    font-family: var(--rb-font-body);
    font-size: 12px;
    color: var(--rb-ink-500);
  }

  .rb-mag-teaser__more {
    margin-top: clamp(32px, 4vw, 48px);
    text-align: center;
  }
</style>
