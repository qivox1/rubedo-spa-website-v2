---
import { site } from '@/lib/site';

// Einheitliches Brand-Icon-Set (Simple Icons — https://simpleicons.org/, CC0).
// Reihenfolge fix: LinkedIn → Instagram → Facebook → YouTube (wie vom Kunden gewünscht).
// Icons werden immer gerendert; sobald URLs in site.social ergänzt sind, werden sie klickbar.
const socials: { key: keyof typeof site.social; label: string; svg: string }[] = [
  {
    key: 'linkedin',
    label: 'LinkedIn',
    svg: `<path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.063 2.063 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>`,
  },
  {
    key: 'instagram',
    label: 'Instagram',
    svg: `<path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919C8.416 2.175 8.796 2.163 12 2.163zm0-2.163C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>`,
  },
  {
    key: 'facebook',
    label: 'Facebook',
    svg: `<path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>`,
  },
  {
    key: 'youtube',
    label: 'YouTube',
    svg: `<path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>`,
  },
];
---

<footer class="rb-footer">
  <div class="rb-wrap">
    <div class="rb-footer__top">
      <div class="rb-footer__brand">
        <div class="rb-brand rb-brand--logo">
          <img class="rb-brand__logo rb-brand__logo--light" src="/logo-rubedo-spa-64.webp" srcset="/logo-rubedo-spa-64.webp 1x, /logo-rubedo-spa-128.webp 2x" alt={site.name} width="64" height="64" data-ai="false" />
          <span hidden>
            <span class="rb-brand__name">{site.name}</span>
            <span class="rb-brand__sub">Smart Beauty · Minden</span>
          </span>
        </div>
        <p>
          Longevity-Studio in Minden. Drei Säulen für bewusste Schönheit —
          DNA Skin Intelligence, Kryo Vital, Inner Source. Geführt von Monica Galletti.
        </p>
        <ul class="rb-footer__socials" aria-label="Social-Media-Profile von Monica Galletti">
          {socials.map((s) => {
            const url = site.social[s.key];
            return (
              <li>
                {url ? (
                  <a href={url} aria-label={`${s.label} — Monica Galletti`} rel="me noopener" target="_blank">
                    <svg viewBox="0 0 24 24" aria-hidden="true" set:html={s.svg} />
                  </a>
                ) : (
                  <span class="is-pending" role="img" aria-label={`${s.label} — Profil folgt in Kürze`} title={`${s.label} — Profil folgt in Kürze`}>
                    <svg viewBox="0 0 24 24" aria-hidden="true" set:html={s.svg} />
                  </span>
                )}
              </li>
            );
          })}
        </ul>
      </div>

      <nav class="rb-footer__col" aria-label="Säulen">
        <h2 class="rb-footer__h">Säulen</h2>
        <ul>
          <li><a href="/dna-skin-intelligence/">DNA Skin Intelligence</a></li>
          <li><a href="/kryo-vital/">Kryo Vital</a></li>
          <li><a href="/kryo-vital/ganzkoerper/">Ganzkörper-Kryo</a></li>
          <li><a href="/kryo-vital/koerperformung/">Körperformung</a></li>
          <li><a href="/inner-source/">Inner Source</a></li>
          <li><a href="/inner-source/rubedo-suite/">Rubedo Suite</a></li>
          <li><a href="/inner-source/atem-ritual/">Atem-Ritual</a></li>
        </ul>
      </nav>

      <nav class="rb-footer__col" aria-label="Studio">
        <h2 class="rb-footer__h">Studio</h2>
        <ul>
          <li><a href="/philosophie/">Philosophie</a></li>
          <li><a href="/longevity-studio-minden/">Longevity-Studio Minden</a></li>
          <li><a href="/ueber-monica/" rel="author">Über Monica Galletti</a></li>
          <li><a href="/kontakt/">Kontakt &amp; Anfahrt</a></li>
          <li><a href="/magazin/">Magazin</a></li>
        </ul>
      </nav>

      <nav class="rb-footer__col" aria-label="Service">
        <h2 class="rb-footer__h">Service</h2>
        <ul>
          <li><a href="/termin-buchen/">Termin buchen</a></li>
          <li><a href="/gutscheine/">Geschenk-Gutscheine</a></li>
          <li><a href="/datenschutz/">Datenschutz</a></li>
          <li><a href="/impressum/">Impressum</a></li>
          <li><a href="/ki-bilder/" rel="license">KI-Bild-Hinweis</a></li>
        </ul>
      </nav>
    </div>

    <div class="rb-footer__bottom">
      <span>© {new Date().getFullYear()} {site.legalName}</span>
      <div class="rb-rule-flourish"><span class="rb-rule-flourish__diamond"></span></div>
      <span>{site.claim}.</span>
    </div>
  </div>
</footer>

<style>
  .rb-footer__socials {
    list-style: none;
    padding: 0;
    margin: 18px 0 0 0;
    display: flex;
    gap: 14px;
  }
  /* Premium-Stil: ruhige Pille, dezenter Hover ohne Spielereien.
     Inspiration Aesop / Loro Piana: Border + Color Shift, kein Fill, kein Wackeln. */
  .rb-footer__socials a,
  .rb-footer__socials .is-pending {
    position: relative;
    display: inline-flex;
    align-items: center; justify-content: center;
    width: 40px; height: 40px;
    border: 1px solid rgba(242,232,210,0.22);
    border-radius: var(--rb-radius-pill);
    color: var(--rb-gold-100);
    background: transparent;
    transition: color 520ms cubic-bezier(.22,.61,.36,1),
                border-color 520ms cubic-bezier(.22,.61,.36,1),
                background-color 520ms cubic-bezier(.22,.61,.36,1),
                box-shadow 520ms cubic-bezier(.22,.61,.36,1),
                transform 520ms cubic-bezier(.22,.61,.36,1);
  }
  /* Sehr feiner Gold-Halo statt sichtbarem Fill — bleibt bei reduced-motion auch sichtbar */
  .rb-footer__socials a::after,
  .rb-footer__socials .is-pending::after {
    content: "";
    position: absolute;
    inset: -1px;
    border-radius: 999px;
    box-shadow: 0 0 0 0 rgba(183,149,87,0);
    transition: box-shadow 520ms cubic-bezier(.22,.61,.36,1);
    pointer-events: none;
  }
  .rb-footer__socials a:hover,
  .rb-footer__socials .is-pending:hover {
    color: var(--rb-paper);
    border-color: var(--rb-gold-500);
    background: rgba(183,149,87,0.10);
    transform: translateY(-1px);
  }
  .rb-footer__socials a:hover::after,
  .rb-footer__socials .is-pending:hover::after {
    box-shadow: 0 0 0 4px rgba(183,149,87,0.16);
  }
  .rb-footer__socials a:focus-visible {
    outline: 2px solid var(--rb-gold-300);
    outline-offset: 3px;
  }
  .rb-footer__socials .is-pending {
    color: rgba(242,232,210,0.55);
    cursor: help;
  }
  .rb-footer__socials svg {
    width: 17px; height: 17px;
    fill: currentColor;
    transition: opacity 520ms cubic-bezier(.22,.61,.36,1);
    opacity: 0.92;
  }
  .rb-footer__socials a:hover svg,
  .rb-footer__socials .is-pending:hover svg { opacity: 1; }
  @media (prefers-reduced-motion: reduce) {
    .rb-footer__socials a, .rb-footer__socials .is-pending,
    .rb-footer__socials a::after, .rb-footer__socials .is-pending::after,
    .rb-footer__socials svg { transition: none; }
    .rb-footer__socials a:hover, .rb-footer__socials .is-pending:hover { transform: none; }
  }
</style>


