---
/**
 * Cookie-Consent — Klaro (kostenfrei, OSS).
 * Konfiguration entkoppelt vom Banner-Code, damit später leicht
 * weitere Services (Meta-Pixel, etc.) ergänzt werden können.
 */
---

<script is:inline>
  // Klaro-Konfig — Default: alle nicht-essentiellen Services aus.
  window.klaroConfig = {
    version: 1,
    elementID: 'klaro',
    storageMethod: 'cookie',
    cookieName: 'klaro',
    cookieExpiresAfterDays: 180,
    default: false,
    mustConsent: false,
    acceptAll: true,
    hideDeclineAll: false,
    hideLearnMore: false,
    noticeAsModal: false,
    htmlTexts: true,
    lang: 'de',
    translations: {
      de: {
        consentModal: {
          title: 'Datenschutz-Einstellungen',
          description:
            'Wir nutzen Cookies, um diese Webseite zu betreiben und um anonym auszuwerten, wie sie genutzt wird. Bitte triff hier deine Auswahl. Mehr Informationen findest du in unserer <a href="/datenschutz/">Datenschutzerklärung</a>.',
        },
        consentNotice: {
          title: '',
          description:
            'Wir nutzen Cookies für anonyme Statistik. {purposes}',
          changeDescription: '',
          learnMore: 'Einstellungen',
        },
        ok: 'Alle akzeptieren',
        decline: 'Nur notwendige',
        save: 'Auswahl speichern',
        purposes: {
          analytics: 'Statistik',
          marketing: 'Marketing',
          functional: 'Funktional',
        },
        purposeItem: { service: 'Service', services: 'Services' },
      },
    },
    services: [
      {
        name: 'google-tag-manager',
        title: 'Google Tag Manager',
        description: 'Steuert das Laden weiterer Analyse-Werkzeuge.',
        purposes: ['analytics'],
        cookies: [['_dc_gtm_*', '/', '.rubedo-spa.de']],
        // Funktionen statt Strings — sonst nutzt Klaro eval() und CSP blockt es.
        onAccept: function() {
          if (typeof window.gtag === 'function') {
            window.gtag('consent', 'update', {
              ad_storage: 'granted',
              analytics_storage: 'granted',
              ad_user_data: 'granted',
              ad_personalization: 'granted',
            });
          }
        },
        onDecline: function() {
          if (typeof window.gtag === 'function') {
            window.gtag('consent', 'update', {
              ad_storage: 'denied',
              analytics_storage: 'denied',
              ad_user_data: 'denied',
              ad_personalization: 'denied',
            });
          }
        },
      },
      {
        name: 'google-analytics',
        title: 'Google Analytics 4',
        description: 'Anonymisierte Nutzungsstatistik (IP-Anonymisierung aktiv).',
        purposes: ['analytics'],
        cookies: [
          ['_ga', '/', '.rubedo-spa.de'],
          [/^_ga_.*/, '/', '.rubedo-spa.de'],
        ],
      },
    ],
  };

  // gtag muss global verfügbar sein, damit Klaro-Callbacks es finden.
  // Falls Analytics.astro noch nicht geladen ist, hier sicheren Fallback definieren.
  if (typeof window.gtag !== 'function') {
    window.dataLayer = window.dataLayer || [];
    window.gtag = function(){ window.dataLayer.push(arguments); };
  }
</script>

<script is:inline>
  // Klaro lazy-load — nicht render-blocking.
  // Wird auf User-Interaktion ODER nach Idle-Callback geladen.
  (function(){
    var loaded = false;
    var load = function(){
      if (loaded) return;
      loaded = true;
      var s = document.createElement('script');
      s.defer = true;
      s.src = 'https://cdn.kiprotect.com/klaro/v0.7.22/klaro.js';
      document.head.appendChild(s);
    };
    var idle = window.requestIdleCallback || function(cb){return setTimeout(cb, 1);};
    ['scroll','click','keydown','touchstart','mousemove'].forEach(function(ev){
      window.addEventListener(ev, load, {once: true, passive: true});
    });
    if (document.readyState === 'complete') {
      idle(load, {timeout: 2500});
    } else {
      window.addEventListener('load', function(){ idle(load, {timeout: 2500}); });
    }
  })();
</script>

<noscript>
  <p style="position:fixed;bottom:0;left:0;right:0;padding:12px;background:var(--rb-ink-900);color:var(--rb-gold-100);font-family:var(--rb-font-body);font-size:14px;text-align:center;z-index:9999;">
    Diese Website nutzt Statistik-Cookies. Ohne JavaScript siehst du diese Hinweis-Zeile dauerhaft.
  </p>
</noscript>
