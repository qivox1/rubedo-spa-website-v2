---
import { site } from '@/lib/site';

interface Props {
  /** Pfad der aktuellen Seite — für Active-State im Menü. */
  currentPath?: string;
}
const { currentPath = '/' } = Astro.props;

function isActive(href: string): boolean {
  if (href === '/') return currentPath === '/';
  return currentPath.startsWith(href);
}

// Nav-Items mit optionalen children flachklopfen für Astro-Templates
type NavLink = { label: string; href: string };
type NavGroup = NavLink & { children?: ReadonlyArray<NavLink & { description?: string }> };
const navItems = site.nav as ReadonlyArray<NavGroup>;
---

<header class="rb-header" data-sticky>
  <div class="rb-wrap rb-header__inner">
    <a class="rb-brand rb-brand--logo" href="/" aria-label={`${site.name} — Startseite`}>
      <img
        class="rb-brand__logo"
        src="/logo-rubedo-spa.webp"
        alt={site.name}
        width="64"
        height="64"
        fetchpriority="high"
      />
    </a>

    <nav class="rb-nav" aria-label="Hauptnavigation">
      {navItems.map((item) => (
        <a
          class={`rb-nav__item${isActive(item.href) ? ' is-active' : ''}${item.children ? ' rb-nav__item--has-sub' : ''}`}
          href={item.href}
          aria-current={isActive(item.href) ? 'page' : undefined}
        >
          {item.label}
        </a>
      ))}
    </nav>

    <a class="rb-btn rb-btn--primary rb-header__cta" href="/termin-buchen/">Termin buchen</a>

    <button
      class="rb-mobile-toggle"
      type="button"
      aria-expanded="false"
      aria-controls="mobile-nav"
      aria-label="Menü öffnen"
      data-mobile-toggle
    >
      <span class="rb-mobile-toggle__bars" aria-hidden="true">
        <span></span>
        <span></span>
        <span></span>
      </span>
    </button>
  </div>
</header>

{/* ----------------------------------------------------------------
    Mobile Drawer — vollflächig, mit Backdrop, Akkordeon für 2. Ebene
    Liegt OUTSIDE des sticky-Headers, damit es 100vh fluten kann.
   ---------------------------------------------------------------- */}
<div class="rb-mnav" id="mobile-nav" data-mobile-nav hidden>
  <button class="rb-mnav__backdrop" type="button" aria-label="Menü schließen" data-mobile-close></button>

  <aside class="rb-mnav__panel" role="dialog" aria-modal="true" aria-label="Hauptnavigation">
    <header class="rb-mnav__head">
      <a class="rb-mnav__brand" href="/" data-mobile-close-link>
        <img src="/logo-rubedo-spa.webp" alt={site.name} width="48" height="48" loading="lazy" />
        <span>
          <strong>Rubedo Spa</strong>
          <em>Smart Beauty · Minden</em>
        </span>
      </a>
      <button class="rb-mnav__close" type="button" aria-label="Menü schließen" data-mobile-close>
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round">
          <path d="M5 5l14 14M19 5L5 19"/>
        </svg>
      </button>
    </header>

    <nav class="rb-mnav__list" aria-label="Mobile Hauptnavigation">
      {navItems.map((item, idx) => {
        const hasChildren = !!item.children && item.children.length > 0;
        const active = isActive(item.href);
        if (!hasChildren) {
          return (
            <a class={`rb-mnav__link${active ? ' is-active' : ''}`} href={item.href} data-mobile-close-link>
              <span>{item.label}</span>
              <svg class="rb-mnav__chevron" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M9 6l6 6-6 6"/>
              </svg>
            </a>
          );
        }
        const groupId = `mnav-grp-${idx}`;
        return (
          <div class={`rb-mnav__group${active ? ' is-active' : ''}${active ? ' is-open' : ''}`}>
            <button
              class="rb-mnav__summary"
              type="button"
              aria-expanded={active ? 'true' : 'false'}
              aria-controls={groupId}
              data-mobile-group
            >
              <span>{item.label}</span>
              <svg class="rb-mnav__caret" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M6 9l6 6 6-6"/>
              </svg>
            </button>
            <div class="rb-mnav__sublist" id={groupId} role="region" aria-label={`${item.label} — Untermenü`}>
              <div class="rb-mnav__sublist-inner">
                <a class="rb-mnav__sublink rb-mnav__sublink--lead" href={item.href} data-mobile-close-link>
                  <span class="rb-mnav__subhead">{item.label} · Übersicht</span>
                  <span class="rb-mnav__subtext">Zur Hauptseite</span>
                </a>
                {item.children!.map((child) => (
                  <a class="rb-mnav__sublink" href={child.href} data-mobile-close-link>
                    <span class="rb-mnav__subhead">{child.label}</span>
                    {child.description && <span class="rb-mnav__subtext">{child.description}</span>}
                  </a>
                ))}
              </div>
            </div>
          </div>
        );
      })}
    </nav>

    <div class="rb-mnav__cta">
      <a class="rb-btn rb-btn--primary rb-btn--lg" href="/termin-buchen/" data-mobile-close-link>Termin buchen</a>
    </div>

    <div class="rb-mnav__contact">
      <a href={`tel:${site.contact.phoneE164}`} class="rb-mnav__contact-item">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6A19.79 19.79 0 0 1 2.12 4.18 2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
        </svg>
        <span>
          <em>Direkt anrufen</em>
          <strong>{site.contact.phoneDisplay}</strong>
        </span>
      </a>
      <a href={`mailto:${site.contact.email}`} class="rb-mnav__contact-item">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
          <polyline points="22,6 12,13 2,6"/>
        </svg>
        <span>
          <em>E-Mail schreiben</em>
          <strong>{site.contact.email}</strong>
        </span>
      </a>
      <p class="rb-mnav__address">
        {site.address.street} · {site.address.postalCode} {site.address.city}<br/>
        Mo–Fr 09:00–19:00 Uhr
      </p>
    </div>
  </aside>
</div>

<script>
  function setupMobileNav() {
    const toggle = document.querySelector<HTMLButtonElement>('[data-mobile-toggle]');
    const drawer = document.querySelector<HTMLElement>('[data-mobile-nav]');
    const closers = document.querySelectorAll<HTMLElement>('[data-mobile-close], [data-mobile-close-link]');

    if (!toggle || !drawer) return;
    // Already initialized? avoid double-binding on view-transition
    if ((drawer as any).__inited) return;
    (drawer as any).__inited = true;

    const open = () => {
      drawer.removeAttribute('hidden');
      // Doppelter rAF, damit der Browser hidden-Removal verarbeitet, BEVOR die Klasse für die Transition gesetzt wird.
      requestAnimationFrame(() => requestAnimationFrame(() => {
        drawer.classList.add('is-open');
        toggle.setAttribute('aria-expanded', 'true');
        toggle.classList.add('is-active');
        document.documentElement.classList.add('rb-noscroll');
      }));
    };

    const close = () => {
      drawer.classList.remove('is-open');
      toggle.setAttribute('aria-expanded', 'false');
      toggle.classList.remove('is-active');
      document.documentElement.classList.remove('rb-noscroll');
      // Nach Transition (320ms) ausblenden
      window.setTimeout(() => {
        if (!drawer.classList.contains('is-open')) drawer.setAttribute('hidden', '');
      }, 360);
    };

    toggle.addEventListener('click', () => {
      if (drawer.classList.contains('is-open')) close();
      else open();
    });

    closers.forEach((el) => el.addEventListener('click', close));

    // Esc schließt
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && drawer.classList.contains('is-open')) close();
    });

    // Beim Wechsel auf Desktop-Viewport sicher schließen
    const mq = window.matchMedia('(min-width: 921px)');
    const onMq = () => { if (mq.matches) close(); };
    mq.addEventListener?.('change', onMq);

    // Akkordeon: Untermenüs öffnen/schließen mit max-height-Animation
    drawer.querySelectorAll<HTMLButtonElement>('[data-mobile-group]').forEach((btn) => {
      btn.addEventListener('click', () => {
        const group = btn.closest<HTMLElement>('.rb-mnav__group');
        const sublist = group?.querySelector<HTMLElement>('.rb-mnav__sublist');
        if (!group || !sublist) return;
        const isOpen = group.classList.toggle('is-open');
        btn.setAttribute('aria-expanded', String(isOpen));
        if (isOpen) {
          sublist.style.maxHeight = sublist.scrollHeight + 'px';
        } else {
          // Erst auf gemessene Höhe setzen, dann auf 0 — sonst klappt's instant
          sublist.style.maxHeight = sublist.scrollHeight + 'px';
          requestAnimationFrame(() => {
            sublist.style.maxHeight = '0px';
          });
        }
      });
    });

    // Initial geöffnete Gruppen sofort auf gemessene Höhe setzen
    drawer.querySelectorAll<HTMLElement>('.rb-mnav__group.is-open .rb-mnav__sublist').forEach((sl) => {
      sl.style.maxHeight = sl.scrollHeight + 'px';
    });
  }

  setupMobileNav();
  document.addEventListener('astro:page-load', setupMobileNav);
</script>

<style is:global>
  /* ===============================================================
     MOBILE NAV — Drawer + Burger-Animation
     =============================================================== */

  /* Body-Scroll-Lock wenn Drawer offen */
  html.rb-noscroll, html.rb-noscroll body { overflow: hidden; touch-action: none; }

  /* ---- Burger ---- */
  .rb-mobile-toggle {
    display: none;
    background: transparent;
    border: 1px solid var(--rb-ink-300);
    color: var(--rb-ink-900);
    width: 44px; height: 44px;
    border-radius: var(--rb-radius-md);
    cursor: pointer;
    align-items: center; justify-content: center;
    transition: border-color var(--rb-dur-1) var(--rb-ease), background var(--rb-dur-1) var(--rb-ease);
  }
  .rb-mobile-toggle:hover { border-color: var(--rb-gold-500); }
  .rb-mobile-toggle__bars {
    position: relative;
    display: inline-block;
    width: 20px; height: 14px;
  }
  .rb-mobile-toggle__bars span {
    position: absolute; left: 0; right: 0;
    height: 1.5px; background: currentColor;
    border-radius: 1px;
    transition: transform 280ms cubic-bezier(.6,-0.28,.74,.05),
                top 280ms cubic-bezier(.6,-0.28,.74,.05) 280ms,
                opacity 0ms linear 280ms;
  }
  .rb-mobile-toggle__bars span:nth-child(1) { top: 0; }
  .rb-mobile-toggle__bars span:nth-child(2) { top: 6px; }
  .rb-mobile-toggle__bars span:nth-child(3) { top: 12px; }
  .rb-mobile-toggle.is-active .rb-mobile-toggle__bars span {
    transition: top 280ms cubic-bezier(.6,-0.28,.74,.05),
                transform 280ms cubic-bezier(.215,.61,.355,1) 280ms,
                opacity 0ms linear 280ms;
  }
  .rb-mobile-toggle.is-active .rb-mobile-toggle__bars span:nth-child(1) { top: 6px; transform: rotate(45deg); }
  .rb-mobile-toggle.is-active .rb-mobile-toggle__bars span:nth-child(2) { opacity: 0; }
  .rb-mobile-toggle.is-active .rb-mobile-toggle__bars span:nth-child(3) { top: 6px; transform: rotate(-45deg); }

  /* ---- Drawer-Wrapper ---- */
  .rb-mnav {
    position: fixed; inset: 0;
    z-index: 100;
    pointer-events: none;
  }
  .rb-mnav[hidden] { display: none; }
  .rb-mnav__backdrop {
    position: absolute; inset: 0;
    background: rgba(15, 12, 10, 0);
    border: 0; padding: 0; cursor: pointer;
    transition: background 320ms cubic-bezier(.2,.65,.3,1);
  }
  .rb-mnav.is-open { pointer-events: auto; }
  .rb-mnav.is-open .rb-mnav__backdrop { background: rgba(15, 12, 10, 0.55); }

  /* ---- Drawer-Panel ---- */
  .rb-mnav__panel {
    position: absolute; top: 0; right: 0; bottom: 0;
    width: min(420px, 92vw);
    background: var(--rb-paper);
    color: var(--rb-ink-900);
    box-shadow: -16px 0 48px rgba(15,12,10,0.18);
    transform: translateX(100%);
    transition: transform 360ms cubic-bezier(.2,.65,.3,1);
    display: flex; flex-direction: column;
    overflow-y: auto;
    overscroll-behavior: contain;
    -webkit-overflow-scrolling: touch;
  }
  .rb-mnav.is-open .rb-mnav__panel { transform: translateX(0); }

  /* ---- Drawer-Header ---- */
  .rb-mnav__head {
    display: flex; align-items: center; justify-content: space-between;
    padding: 18px 24px;
    border-bottom: 1px solid var(--rb-ink-100);
    background:
      radial-gradient(120% 80% at 100% 0%, rgba(183,149,87,0.08), transparent 60%),
      var(--rb-paper);
  }
  .rb-mnav__brand {
    display: inline-flex; align-items: center; gap: 12px;
    text-decoration: none; color: var(--rb-ink-900);
  }
  .rb-mnav__brand img { width: 44px; height: 44px; display: block; }
  .rb-mnav__brand strong {
    display: block;
    font-family: var(--rb-font-display); font-weight: 400;
    font-size: 20px; line-height: 1;
    letter-spacing: 0.005em;
  }
  .rb-mnav__brand em {
    display: block;
    font-style: normal;
    font-family: var(--rb-font-body); font-size: 11px;
    letter-spacing: 0.18em; text-transform: uppercase;
    color: var(--rb-ink-500); margin-top: 4px;
  }
  .rb-mnav__close {
    width: 40px; height: 40px;
    display: inline-flex; align-items: center; justify-content: center;
    background: transparent;
    border: 1px solid var(--rb-ink-100);
    border-radius: 50%;
    color: var(--rb-ink-700);
    cursor: pointer;
    transition: color var(--rb-dur-1) var(--rb-ease), border-color var(--rb-dur-1) var(--rb-ease), background var(--rb-dur-1) var(--rb-ease);
  }
  .rb-mnav__close:hover {
    color: var(--rb-paper);
    background: var(--rb-ink-900);
    border-color: var(--rb-ink-900);
  }

  /* ---- Liste ---- */
  .rb-mnav__list {
    display: flex; flex-direction: column;
    padding: 8px 0;
    border-bottom: 1px solid var(--rb-ink-100);
  }
  .rb-mnav__link,
  .rb-mnav__summary {
    display: flex; align-items: center; justify-content: space-between;
    width: 100%;
    padding: 16px 24px;
    text-align: left;
    text-decoration: none;
    color: var(--rb-ink-900);
    background: transparent;
    border: 0;
    font-family: var(--rb-font-display); font-weight: 400;
    font-size: 22px; line-height: 1.2;
    cursor: pointer;
    transition: background var(--rb-dur-1) var(--rb-ease), color var(--rb-dur-1) var(--rb-ease);
  }
  .rb-mnav__link:hover,
  .rb-mnav__summary:hover { background: var(--rb-cream); }
  .rb-mnav__link.is-active,
  .rb-mnav__group.is-active > .rb-mnav__summary { color: var(--rb-gold-700); }
  .rb-mnav__link.is-active { box-shadow: inset 3px 0 0 var(--rb-gold-500); }
  .rb-mnav__group.is-active { box-shadow: inset 3px 0 0 var(--rb-gold-500); }

  .rb-mnav__chevron { color: var(--rb-ink-300); transition: transform var(--rb-dur-1) var(--rb-ease), color var(--rb-dur-1) var(--rb-ease); }
  .rb-mnav__link:hover .rb-mnav__chevron { transform: translateX(3px); color: var(--rb-gold-700); }

  .rb-mnav__caret { color: var(--rb-ink-500); transition: transform 280ms cubic-bezier(.2,.65,.3,1); }
  .rb-mnav__group.is-open > .rb-mnav__summary .rb-mnav__caret { transform: rotate(180deg); color: var(--rb-gold-700); }

  /* ---- Untermenü (zweite Ebene) ---- */
  .rb-mnav__sublist {
    background: var(--rb-cream);
    border-top: 1px solid var(--rb-ink-100);
    max-height: 0;
    overflow: hidden;
    transition: max-height 360ms cubic-bezier(.2,.65,.3,1);
  }
  .rb-mnav__sublist-inner { padding: 4px 0; }
  .rb-mnav__sublink {
    display: block;
    padding: 14px 24px 14px 40px;
    text-decoration: none;
    color: var(--rb-ink-700);
    border-left: 3px solid transparent;
    transition: background var(--rb-dur-1) var(--rb-ease), border-color var(--rb-dur-1) var(--rb-ease), color var(--rb-dur-1) var(--rb-ease);
  }
  .rb-mnav__sublink:hover {
    background: var(--rb-paper);
    border-left-color: var(--rb-gold-500);
    color: var(--rb-ink-900);
  }
  .rb-mnav__subhead {
    display: block;
    font-family: var(--rb-font-body); font-weight: 500;
    font-size: 15px; line-height: 1.3;
    color: var(--rb-ink-900);
  }
  .rb-mnav__subtext {
    display: block;
    margin-top: 4px;
    font-family: var(--rb-font-body); font-size: 12px;
    line-height: 1.45;
    color: var(--rb-ink-500);
  }
  .rb-mnav__sublink--lead .rb-mnav__subhead { color: var(--rb-gold-700); }

  /* ---- CTA + Kontakt ---- */
  .rb-mnav__cta {
    display: flex; flex-direction: column;
    padding: 20px 24px 8px;
  }
  .rb-mnav__cta .rb-btn { justify-content: center; text-align: center; }

  .rb-mnav__contact {
    padding: 12px 24px 32px;
    display: flex; flex-direction: column; gap: 4px;
  }
  .rb-mnav__contact-item {
    display: flex; align-items: center; gap: 14px;
    padding: 14px 0;
    border-top: 1px solid var(--rb-ink-100);
    text-decoration: none; color: var(--rb-ink-900);
  }
  .rb-mnav__contact-item:first-child { border-top: 0; }
  .rb-mnav__contact-item svg { color: var(--rb-gold-700); flex-shrink: 0; }
  .rb-mnav__contact-item em {
    display: block;
    font-style: normal;
    font-family: var(--rb-font-body); font-size: 11px;
    letter-spacing: 0.16em; text-transform: uppercase;
    color: var(--rb-ink-500); margin-bottom: 3px;
  }
  .rb-mnav__contact-item strong {
    display: block;
    font-family: var(--rb-font-body); font-weight: 500;
    font-size: 15px; line-height: 1.3;
    color: var(--rb-ink-900);
  }
  .rb-mnav__address {
    margin: 12px 0 0;
    font-family: var(--rb-font-body); font-size: 12px;
    line-height: 1.5; color: var(--rb-ink-500);
  }

  /* ---- Breakpoints ---- */
  @media (max-width: 920px) {
    .rb-nav { display: none !important; }
    .rb-header__cta { display: none !important; }
    .rb-mobile-toggle { display: inline-flex; }
  }

  /* Reduced motion: harte Toggle ohne Slide */
  @media (prefers-reduced-motion: reduce) {
    .rb-mnav__panel,
    .rb-mnav__backdrop,
    .rb-mobile-toggle__bars span,
    .rb-mnav__sublist { transition: none !important; }
    .rb-mnav__group.is-open .rb-mnav__sublist { max-height: none !important; }
  }
</style>
