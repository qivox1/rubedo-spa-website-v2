---
import { ClientRouter } from 'astro:transitions';
import { site } from '@/lib/site';
import SiteTopbar from '@/components/SiteTopbar.astro';
import SiteHeader from '@/components/SiteHeader.astro';
import SiteFooter from '@/components/SiteFooter.astro';
import SchemaOrg from '@/components/SchemaOrg.astro';
import Analytics from '@/components/Analytics.astro';
import ConsentBanner from '@/components/ConsentBanner.astro';
import '@/styles/global.css';

interface Props {
  title: string;
  description: string;
  /** Page-spezifisches Hero-Bild (LCP-Preload). */
  heroImage?: string;
  /** Canonical URL — Default: aktuelle Astro-URL. */
  canonical?: string;
  /** Optional: ergänzende JSON-LD Blöcke. */
  schemaExtras?: Record<string, unknown>[];
  /** Optional: Open-Graph-Bild. */
  ogImage?: string;
  /** noindex setzen (z. B. für 404). */
  noindex?: boolean;
  /** Article-spezifische Meta-Tags (für Magazin-Artikel). */
  articleMeta?: {
    author?: string;
    authorUrl?: string;
    publishedTime?: string;
    modifiedTime?: string;
    section?: string;
    tags?: string[];
  };
}

const {
  title,
  description,
  heroImage,
  canonical,
  schemaExtras,
  ogImage,
  noindex = false,
  articleMeta,
} = Astro.props;

const fullTitle = title.includes('Rubedo') ? title : `${title} | Rubedo Spa Minden`;
const canonicalUrl = canonical ?? new URL(Astro.url.pathname, site.url).href;
const ogImg = ogImage ?? `${site.url}/logo-rubedo-spa.webp`;
const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />

    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    {noindex && <meta name="robots" content="noindex,nofollow" />}

    {/* Open Graph / Twitter */}
    <meta property="og:type" content={articleMeta ? 'article' : 'website'} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImg} />
    <meta property="og:locale" content="de_DE" />
    <meta property="og:site_name" content={site.name} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImg} />

    {/* Author + Article-spezifische Meta-Tags (E-E-A-T) */}
    {articleMeta?.author && <meta name="author" content={articleMeta.author} />}
    {articleMeta?.author && <meta property="article:author" content={articleMeta.author} />}
    {articleMeta?.authorUrl && <link rel="author" href={articleMeta.authorUrl} />}
    {articleMeta?.publishedTime && <meta property="article:published_time" content={articleMeta.publishedTime} />}
    {articleMeta?.modifiedTime && <meta property="article:modified_time" content={articleMeta.modifiedTime} />}
    {articleMeta?.section && <meta property="article:section" content={articleMeta.section} />}
    {articleMeta?.tags?.map((tag) => <meta property="article:tag" content={tag} />)}

    <meta name="theme-color" content="#FBF8F1" />
    <meta name="format-detection" content="telephone=no" />

    {/* Favicons */}
    <link rel="icon" type="image/svg+xml" href="/logo-rubedo-spa.svg" />
    <link rel="alternate icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" href="/logo-rubedo-spa.png" />

    {/* Preload des Logos auf Seiten ohne dediziertes heroImage — verhindert,
        dass das Logo zum LCP-Element wird ohne Preload-Hint. */}
    {!heroImage && (
      <link rel="preload" as="image" href="/logo-rubedo-spa-64.webp" imagesrcset="/logo-rubedo-spa-64.webp 1x, /logo-rubedo-spa-128.webp 2x" fetchpriority="high" />
    )}

    {/* Self-hosted Fonts — preload der wichtigsten Latin-Variants (LCP-Fonts).
        Beide Familien als Variable-Fonts → eine Datei pro Variante. */}
    <link rel="preload" as="font" type="font/woff2" href="/fonts/outfit-latin.woff2" crossorigin />
    <link rel="preload" as="font" type="font/woff2" href="/fonts/cormorant-garamond-latin.woff2" crossorigin />

    {/* RSS-Feed des Magazins */}
    <link rel="alternate" type="application/rss+xml" title={`${site.name} — Magazin`} href="/magazin/rss.xml" />

    {/* LCP-Preload für Hero-Bild */}
    {heroImage && (
      <link rel="preload" as="image" href={heroImage} fetchpriority="high" />
    )}

    {/* Reveal-On-Scroll Opt-In: BEVOR der erste Render passiert,
        markieren wir das Document mit `js-reveal`. Erst dann greift
        die CSS-Regel, die data-reveal-Elemente initial versteckt.
        Ohne diese Klasse sind ALLE Inhalte sofort sichtbar — kein FOUC. */}
    <script is:inline>
      document.documentElement.classList.add('js-reveal');
    </script>

    {/* View-Transitions / Astro ClientRouter */}
    <ClientRouter fallback="swap" />

    {/* Strukturierte Daten */}
    <SchemaOrg extras={schemaExtras} />

    {/* Analytics — bevor Klaro lädt, mit Consent Mode default-deny */}
    <Analytics />
  </head>
  <body>
    <a class="skip-link" href="#main">Zum Hauptinhalt springen</a>

    <SiteTopbar />
    <SiteHeader currentPath={currentPath} />

    <main id="main">
      <slot />
    </main>

    <SiteFooter />

    {/* Cookie-Consent — am Ende des Body, damit Banner immer sichtbar */}
    <ConsentBanner />

    {/* Reveal-On-Scroll: progressive enhancement.
        Bereits sichtbare Elemente (above the fold) werden SOFORT freigegeben,
        damit der Hero nicht auf den IntersectionObserver wartet. */}
    <script>
      function initReveal() {
        const els = document.querySelectorAll<HTMLElement>('[data-reveal]');
        if (!els.length) return;

        // Above-the-fold: synchron freigeben, kein Warten auf Observer.
        const vh = window.innerHeight || document.documentElement.clientHeight;
        const toObserve: HTMLElement[] = [];
        els.forEach((el) => {
          const r = el.getBoundingClientRect();
          if (r.top < vh * 0.95) {
            el.classList.add('is-revealed');
          } else {
            toObserve.push(el);
          }
        });

        if ('IntersectionObserver' in window && toObserve.length) {
          const io = new IntersectionObserver((entries) => {
            entries.forEach((e) => {
              if (e.isIntersecting) {
                e.target.classList.add('is-revealed');
                io.unobserve(e.target);
              }
            });
          }, { rootMargin: '0px 0px -10% 0px', threshold: 0.05 });
          toObserve.forEach((el) => io.observe(el));
        } else {
          toObserve.forEach((el) => el.classList.add('is-revealed'));
        }
      }

      initReveal();
      // Bei View-Transition-Navigation neu initialisieren.
      document.addEventListener('astro:page-load', initReveal);
    </script>
  </body>
</html>
