---
import { getCollection, getEntry } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { site } from '@/lib/site';
import { estimateReadingTime } from '@/lib/reading-time';

export async function getStaticPaths() {
  const entries = await getCollection('magazin', ({ data }) => !data.draft);
  return entries.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

interface Props { entry: CollectionEntry<'magazin'>; }
const { entry } = Astro.props;
const { data } = entry;
const { Content, headings } = await entry.render();

// Author auflösen
const author = await getEntry(data.author);

// Lesezeit — manuell oder geschätzt aus Body-Text
const bodyText = entry.body ?? '';
const readingTime = data.readingTime ?? estimateReadingTime(bodyText);

// TOC — manuell aus Frontmatter ODER automatisch aus h2/h3
const toc =
  data.toc && data.toc.length > 0
    ? data.toc
    : headings.filter((h) => h.depth === 2).map((h) => ({ id: h.slug, label: h.text }));

// Verwandte Artikel auflösen — wenn keine manuelle Liste, fallback auf
// jüngste 3 Artikel der gleichen Kategorie (ohne den aktuellen).
const allArticles = await getCollection('magazin', ({ data }) => !data.draft);
let related: CollectionEntry<'magazin'>[] = [];
if (data.related && data.related.length > 0) {
  related = data.related
    .map((slug) => allArticles.find((a) => a.slug === slug))
    .filter((a): a is CollectionEntry<'magazin'> => Boolean(a));
}
if (related.length < 3) {
  const sameCat = allArticles
    .filter((a) => a.slug !== entry.slug && a.data.category === data.category)
    .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
  for (const a of sameCat) {
    if (related.length >= 3) break;
    if (!related.some((r) => r.slug === a.slug)) related.push(a);
  }
}
if (related.length < 3) {
  const others = allArticles
    .filter((a) => a.slug !== entry.slug && !related.some((r) => r.slug === a.slug))
    .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
  for (const a of others) {
    if (related.length >= 3) break;
    related.push(a);
  }
}

// Daten formatieren
const fmtDate = (d: Date) =>
  new Intl.DateTimeFormat('de-DE', { day: 'numeric', month: 'long', year: 'numeric' }).format(d);
const pubDateFmt = fmtDate(data.pubDate);
const updatedDateFmt = data.updatedDate ? fmtDate(data.updatedDate) : null;

// Schema.org Article + ggf. FAQPage
const url = `${site.url}/magazin/${entry.slug}/`;
const authorPageUrl = author.data.page ? `${site.url}${author.data.page}` : `${site.url}/ueber-monica/`;
/* Person-Knoten via @id auf den vollen Person-Knoten der Vita-Page referenzieren
   (statt eine Mini-Person inline zu duplizieren). Das verbindet jeden Magazin-
   Artikel im Knowledge-Graph mit jobTitle/hasCredential/knowsAbout etc. der
   Author-Seite — entscheidend für E-E-A-T. */
const authorRef = { '@id': `${authorPageUrl}#monica` };

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  '@id': `${url}#article`,
  headline: data.headline ?? data.title,
  description: data.description,
  image: `${site.url}${data.heroImage}`,
  datePublished: data.pubDate.toISOString(),
  dateModified: (data.updatedDate ?? data.pubDate).toISOString(),
  inLanguage: 'de-DE',
  author: authorRef,
  /* creator als Synonym zu author — manche AI-Crawler nutzen creator. */
  creator: authorRef,
  publisher: {
    '@type': 'Organization',
    '@id': `${site.url}/#localbusiness`,
    name: site.name,
    logo: { '@type': 'ImageObject', url: `${site.url}/logo-rubedo-spa.png` },
  },
  mainEntityOfPage: { '@type': 'WebPage', '@id': url },
  /* isPartOf — bindet den Artikel ans Magazin und damit an die Brand. */
  isPartOf: {
    '@type': 'PublicationIssue',
    '@id': `${site.url}/magazin/#magazin`,
    name: `${site.name} Magazin`,
    isPartOf: { '@type': 'Periodical', '@id': `${site.url}/#website`, name: site.name },
  },
  articleSection: data.category,
  keywords: data.tags.join(', '),
  /* Speakable: markiert Lead und FAQ als sprachfähig — relevant für Voice
     Search, Google Assistant und AI-Citation. CSS-Selektoren matchen die
     gerenderten Bereiche im Layout. */
  speakable: {
    '@type': 'SpeakableSpecification',
    cssSelector: ['.rb-mag-prose > blockquote:first-child', '.rb-mag-faq__item summary', '.rb-mag-faq__item p'],
  },
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Startseite', item: `${site.url}/` },
    { '@type': 'ListItem', position: 2, name: 'Magazin', item: `${site.url}/magazin/` },
    { '@type': 'ListItem', position: 3, name: data.title, item: url },
  ],
};

const schemaExtras: Record<string, unknown>[] = [articleSchema, breadcrumbSchema];

if (data.faq && data.faq.length > 0) {
  schemaExtras.push({
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    /* FAQ-Page-Schema inhaltlich an Article geknüpft — verbindet die Frage-
       Antwort-Paare mit dem Artikel im Knowledge-Graph. */
    mainEntityOfPage: { '@id': `${url}#article` },
    mainEntity: data.faq.map((f, i) => ({
      '@type': 'Question',
      '@id': `${url}#faq-${i + 1}`,
      name: f.question,
      acceptedAnswer: { '@type': 'Answer', text: f.answer, author: authorRef },
    })),
  });
}
---

<BaseLayout
  title={data.title}
  description={data.description}
  heroImage={data.heroImage}
  ogImage={data.ogImage ?? data.heroImage}
  canonical={data.canonical}
  schemaExtras={schemaExtras}
  articleMeta={{
    author: author.data.name,
    authorUrl: author.data.page ? `${site.url}${author.data.page}` : undefined,
    publishedTime: data.pubDate.toISOString(),
    modifiedTime: (data.updatedDate ?? data.pubDate).toISOString(),
    section: data.category,
    tags: data.tags,
  }}
>
  <article class="rb-page" data-page="magazin-artikel" itemscope itemtype="https://schema.org/Article">

    <div class="rb-mag-progress" aria-hidden="true">
      <div class="rb-mag-progress__bar" id="rb-mag-bar"></div>
    </div>

    {/* HERO */}
    <section class="rb-mag-hero">
      <div class="rb-mag-hero__photo">
        <img src={data.heroImage} alt={data.heroImageAlt} width="1600" height="900" fetchpriority="high" />
      </div>
      <div class="rb-wrap">
        <div class="rb-mag-hero__inner">
          <nav class="rb-mag-hero__crumbs" aria-label="Breadcrumb">
            <a href="/">Startseite</a>
            <span class="sep">/</span>
            <a href="/magazin/">Magazin</a>
            <span class="sep">/</span>
            <span>{data.title}</span>
          </nav>
          <span class="rb-mag-hero__cat">{data.category}</span>
          <h1>{data.headline ?? data.title}</h1>
          <p class="rb-mag-hero__meta byline author">
            <span class="rb-mag-hero__meta-item" itemprop="author" itemscope itemtype="https://schema.org/Person">
              von <a class="byline author rel-author p-author h-card vcard" rel="author" href={author.data.page ?? '/ueber-monica/'} itemprop="url"><strong class="fn p-name" itemprop="name">{author.data.name}</strong></a>
            </span>
            <span class="rb-mag-hero__meta-item">
              veröffentlicht am
              <time class="published dt-published entry-date" datetime={data.pubDate.toISOString()} pubdate="pubdate" itemprop="datePublished">{pubDateFmt}</time>
              {updatedDateFmt && (
                <>, aktualisiert am <time class="updated dt-updated" datetime={data.updatedDate!.toISOString()} itemprop="dateModified">{updatedDateFmt}</time></>
              )}
            </span>
            <span class="rb-mag-hero__meta-item">{readingTime} Min. Lesezeit</span>
          </p>
        </div>
      </div>
    </section>

    {/* BODY: TOC + Prose */}
    <section class="rb-section rb-section--paper">
      <div class="rb-wrap">
        <div class="rb-mag-body">

          {toc.length > 0 && (
            <aside class="rb-mag-toc" aria-label="Inhaltsverzeichnis">
              <div class="rb-mag-toc__label">Inhalt</div>
              <ul>
                {toc.map((item) => (
                  <li><a href={`#${item.id}`} class="rb-mag-toc-link">{item.label}</a></li>
                ))}
              </ul>
            </aside>
          )}

          <div class="rb-mag-prose">
            <Content />

            {data.faq && data.faq.length > 0 && (
              <section class="rb-mag-faq" id="faq">
                <h2>Häufige Fragen</h2>
                {data.faq.map((item) => (
                  <details class="rb-mag-faq__item">
                    <summary>{item.question}</summary>
                    <p>{item.answer}</p>
                  </details>
                ))}
              </section>
            )}

            {data.tags.length > 0 && (
              <p class="rb-mag-tags" aria-label="Themen dieses Beitrags">
                <span class="rb-mag-tags__label">Themen</span>
                {data.tags.map((tag, i) => (
                  <>
                    {i > 0 && <span class="rb-mag-tags__sep" aria-hidden="true">·</span>}
                    <span class="rb-mag-tags__item">{tag}</span>
                  </>
                ))}
              </p>
            )}
          </div>

        </div>

        {/* Author-Box · Briefkopf-Look — keine Hintergrund-Box mehr,
            stattdessen Cream-Hairline als Schnitt + signaturartige Anmutung */}
        <aside class="rb-mag-author" aria-label="Über die Autorin">
          <span class="rb-mag-author__eyebrow">Gezeichnet von</span>
          <div class="rb-mag-author__row">
            <img class="rb-mag-author__avatar" src="/images/monica-portrait-96.webp" srcset="/images/monica-portrait-96.webp 1x, /images/monica-portrait-sm.webp 2x" alt={author.data.name} loading="lazy" width="64" height="64" />
            <div class="rb-mag-author__body">
              <h3 class="rb-mag-author__name">{author.data.name}</h3>
              <p class="rb-mag-author__bio">{author.data.bio}</p>
              {author.data.page && (
                <a class="rb-mag-author__link" href={author.data.page}>Zur Vita →</a>
              )}
            </div>
          </div>
        </aside>

      </div>
    </section>

    {/* Verwandte Artikel — Editorial-Karten 1:1 zum Design */}
    {related.length > 0 && (
      <section class="rb-mag-related">
        <div class="rb-wrap">
          <div class="rb-mag-related__head">
            <h3>Weiter im Magazin</h3>
            <a href="/magazin/" class="rb-btn rb-btn--link">Alle Artikel →</a>
          </div>
          <div class="rb-mag-related__grid">
            {related.map((rel) => (
              <a class="rb-mag-card" href={`/magazin/${rel.slug}/`}>
                <div class="rb-mag-card__photo" style={`background-image: url('${rel.data.heroImage}');`}>
                  <span class="rb-mag-card__cat">{rel.data.category}</span>
                </div>
                <div class="rb-mag-card__body">
                  <h4 class="rb-mag-card__title">{rel.data.title}</h4>
                  <div class="rb-mag-card__meta">
                    {fmtDate(rel.data.pubDate)}
                    {rel.data.readingTime && <> · {rel.data.readingTime} Min. Lesezeit</>}
                  </div>
                </div>
              </a>
            ))}
          </div>
        </div>
      </section>
    )}

  </article>
</BaseLayout>

<script>
  // Reading-Progress-Bar (lightweight, ohne Framework)
  const bar = document.getElementById('rb-mag-bar');
  if (bar) {
    const onScroll = () => {
      const h = document.documentElement;
      const scrolled = h.scrollTop;
      const max = h.scrollHeight - h.clientHeight;
      const pct = max > 0 ? (scrolled / max) * 100 : 0;
      bar.style.width = `${pct}%`;
    };
    document.addEventListener('scroll', onScroll, { passive: true });
    onScroll();
  }
</script>

<style>
  /* Themen-Zeile statt Hashtag-Pillen — eine ruhige Capitals-Liste mit
     Mid-Dot-Trennern. Wirkt wie ein redaktioneller Kategorisierungs-
     Hinweis am Artikelende, nicht wie eine Twitter-Tag-Cloud. */
  .rb-mag-tags {
    display: flex; flex-wrap: wrap; align-items: baseline;
    gap: 8px;
    margin: 48px 0 0;
    font-family: var(--rb-font-body);
    font-size: 11px;
    letter-spacing: var(--rb-tracking-wider);
    text-transform: uppercase;
  }
  .rb-mag-tags__label {
    color: var(--rb-gold-700);
    font-weight: 500;
    margin-right: 4px;
  }
  .rb-mag-tags__item {
    color: var(--rb-ink-500);
  }
  .rb-mag-tags__sep {
    color: var(--rb-red-500);
    opacity: 0.85;
    font-weight: 700;
  }
  /* FAQ-Block — Premium-Akkordeon mit Diamond-Marker.
     Vorher: Standard-Disclosure mit großem '+' in Gold, Trennlinien in Ink-100.
     Jetzt: Frage in Cormorant Display, Diamond-Marker in Red 500 (analog zur
     Brand-Diamond-Logik überall sonst), Trennlinien in Cream — wirkt deutlich
     editorialer und passt visuell zum Rest der Site. */
  .rb-mag-faq {
    margin-top: 64px;
    padding-top: 32px;
    border-top: 1px solid var(--rb-cream);
  }
  .rb-mag-faq h2 {
    font-family: var(--rb-font-display);
    font-weight: 400;
    font-size: clamp(26px, 2.4vw, 34px);
    margin: 0 0 24px;
    color: var(--rb-ink-900);
  }
  .rb-mag-faq__item {
    border-bottom: 1px solid var(--rb-cream);
    padding: 18px 0;
  }
  .rb-mag-faq__item:last-child { border-bottom: 0; }
  .rb-mag-faq__item summary {
    font-family: var(--rb-font-display);
    font-weight: 400;
    font-size: 19px;
    line-height: 1.35;
    cursor: pointer;
    color: var(--rb-ink-900);
    list-style: none;
    position: relative;
    padding-right: 32px;
    text-wrap: balance;
  }
  .rb-mag-faq__item summary::-webkit-details-marker { display: none; }
  /* Diamond-Marker rechts: im closed-State 6×6 px Raute in Red 500,
     im open-State zur vertikalen Hairline gestreckt — gleiche Brand-Logik
     wie sonst überall, ohne Plus/Minus-Zeichen-Sprache. */
  .rb-mag-faq__item summary::after {
    content: '';
    position: absolute; right: 4px; top: 8px;
    width: 6px; height: 6px;
    background: var(--rb-red-500);
    transform: rotate(45deg);
    transition: transform var(--rb-dur-2) var(--rb-ease),
                width var(--rb-dur-2) var(--rb-ease),
                height var(--rb-dur-2) var(--rb-ease);
  }
  .rb-mag-faq__item[open] summary::after {
    width: 2px; height: 14px;
    transform: rotate(0);
    right: 6px; top: 4px;
  }
  .rb-mag-faq__item p {
    margin: 14px 0 0;
    font-family: var(--rb-font-body);
    font-size: 15px;
    color: var(--rb-ink-700);
    line-height: 1.65;
    max-width: 64ch;
  }
  /* Briefkopf-Author-Box: Hintergrund-Box ist ersatzlos weg.
     Stattdessen ein Cream-Hairline als visueller Schnitt, darüber das
     "Gezeichnet von"-Eyebrow als handschriftliches Signatur-Pattern.
     Avatar 64×64 mit Cream-Stempel-Outline (analog Footer-Logo).
     Wirkt wie eine signierte Briefseite, nicht wie ein WordPress-Block. */
  .rb-mag-author {
    margin-top: 56px;
    padding-top: 28px;
    border-top: 1px solid var(--rb-cream);
  }
  .rb-mag-author__eyebrow {
    display: block;
    font-family: var(--rb-font-body);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: var(--rb-tracking-widest);
    text-transform: uppercase;
    color: var(--rb-gold-700);
    margin-bottom: 16px;
  }
  .rb-mag-author__row {
    display: flex; gap: 18px;
    align-items: flex-start;
  }
  .rb-mag-author__avatar {
    width: 64px; height: 64px;
    border-radius: var(--rb-radius-pill);
    object-fit: cover;
    flex-shrink: 0;
    background: var(--rb-cream);
    box-shadow:
      0 0 0 1px var(--rb-gold-300),
      0 0 0 4px rgba(215, 189, 134, 0.10);
  }
  .rb-mag-author__body { padding-top: 2px; }
  .rb-mag-author__name {
    font-family: var(--rb-font-display);
    font-weight: 400;
    font-size: 22px;
    line-height: 1.2;
    letter-spacing: -0.005em;
    color: var(--rb-ink-900);
    margin: 0 0 6px;
  }
  .rb-mag-author__bio {
    font-family: var(--rb-font-body);
    font-size: 14px;
    color: var(--rb-ink-500);
    line-height: 1.55;
    margin: 0 0 10px;
    max-width: 56ch;
  }
  .rb-mag-author__link {
    display: inline-block;
    font-family: var(--rb-font-body);
    font-size: 12px;
    font-weight: 500;
    letter-spacing: var(--rb-tracking-wide);
    text-transform: uppercase;
    color: var(--rb-gold-700);
    text-decoration: none;
    border-bottom: 1px solid var(--rb-gold-300);
    padding-bottom: 2px;
    transition: border-color var(--rb-dur-1) var(--rb-ease), color var(--rb-dur-1) var(--rb-ease);
  }
  .rb-mag-author__link:hover {
    color: var(--rb-ink-900);
    border-bottom-color: var(--rb-red-500);
  }
</style>
