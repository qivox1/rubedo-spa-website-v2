---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { site } from '@/lib/site';

const title = 'KI-Bilder & C2PA — Transparenz Rubedo Spa Minden';
const description = 'Kennzeichnung KI-generierter Bilder gemäß EU AI Act und C2PA Content Credentials — wie Rubedo Spa Minden KI einsetzt und was die „cr"-Markierung bedeutet.';
const url = `${site.url}/ki-bilder/`;

const aboutPageSchema = {
  '@context': 'https://schema.org',
  '@type': 'AboutPage',
  '@id': `${url}#aboutpage`,
  url,
  name: title,
  description,
  inLanguage: 'de-DE',
  isPartOf: { '@type': 'WebSite', '@id': `${site.url}/#website`, url: site.url, name: site.name },
  mainEntity: { '@id': `${site.url}/#localbusiness` },
  breadcrumb: {
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Startseite', item: `${site.url}/` },
      { '@type': 'ListItem', position: 2, name: 'KI-Bild-Hinweis', item: url },
    ],
  },
};
---

<BaseLayout
  title={title}
  description={description}
  schemaExtras={[aboutPageSchema]}
>
  <article class="rb-page" data-page="ki-bilder">
    <section class="rb-section rb-section--paper">
      <div class="rb-wrap rb-wrap--narrow rb-prose">
        <h1>KI-Bild-Hinweis &amp; Content Credentials</h1>
        <p class="rb-eyebrow" style="margin-bottom: 24px;">Stand: {new Date().toLocaleDateString('de-DE', { year: 'numeric', month: 'long' })}</p>

        <p class="rb-lead">
          Auf rubedo-spa.de werden Bildinhalte überwiegend mit Hilfe generativer
          Künstlicher Intelligenz erstellt oder mit KI-gestützten Werkzeugen
          nachbearbeitet. Wir kennzeichnen das transparent — sowohl visuell auf
          jedem Bild als auch auf dieser Seite. Damit erfüllen wir bereits heute
          die Transparenzpflichten, die ab dem 2. August 2026 europaweit gelten.
        </p>

        <nav class="rb-toc" aria-label="Inhaltsverzeichnis">
          <strong>Auf dieser Seite</strong>
          <ol>
            <li><a href="#kennzeichnung">Was bedeutet das „cr"-Pin?</a></li>
            <li><a href="#warum">Warum wir KI-Bilder einsetzen</a></li>
            <li><a href="#persona">Hinweis zur wiederkehrenden Klientinnen-Persona</a></li>
            <li><a href="#location">Hinweis zu den Studio-Fotos</a></li>
            <li><a href="#tools">Eingesetzte Werkzeuge</a></li>
            <li><a href="#rechtsgrundlagen">Rechtsgrundlagen</a></li>
            <li><a href="#kontakt">Fragen oder Beanstandungen</a></li>
          </ol>
        </nav>

        <h2 id="kennzeichnung">Was bedeutet das „cr"-Pin?</h2>
        <p>
          Das kleine kreisförmige Symbol mit den Buchstaben <strong>„cr"</strong>
          oben rechts auf jedem KI-erzeugten Bild ist die offizielle Kennzeichnung
          der <a href="https://c2pa.org/" rel="noopener" target="_blank">Coalition for
          Content Provenance and Authenticity (C2PA)</a>. C2PA ist ein
          industrieweiter Standard, der von Adobe, Microsoft, Google, BBC,
          Sony, Reuters und anderen entwickelt und gepflegt wird. Das Pin steht
          für „Content Credentials" und signalisiert Betrachtenden:
          <em>„Dieses Bild wurde maschinell erzeugt oder substanziell mit KI
          bearbeitet."</em>
        </p>
        <p>
          Wir setzen die minimalistische Variante des Pins ein. Beim Hover über
          das Symbol erscheint ein Tooltip; beim Klick gelangst du auf diese
          Seite mit allen Hintergrund-Informationen.
        </p>

        <h2 id="warum">Warum wir KI-Bilder einsetzen</h2>
        <p>
          Eine professionelle, durchgängig stimmige Bildwelt ist im Premium-Spa-
          und Longevity-Segment wesentlich für die Wahrnehmung der Marke.
          Klassische Bildproduktion mit Modell, Set, Studio und Postproduktion
          ist ressourcenintensiv und reicht selten für die Vielzahl an
          Bildanlässen, die eine moderne Webseite verlangt. Mit kuratierten
          KI-Bildern können wir
        </p>
        <ul>
          <li>eine konsistente, ruhige Bildsprache über alle Seiten hinweg halten,</li>
          <li>auf vielfältige Behandlungs- und Ritualkontexte editorial reagieren,</li>
          <li>ohne Stockfotografie auskommen, die in fast jedem Wellness-Auftritt
              identisch wiederverwendet wird.</li>
        </ul>
        <p>
          Wir setzen KI bewusst und sparsam ein. Wo eine reale Aufnahme
          aussagekräftiger ist (z. B. das Studio-Gebäude in der Marienstraße),
          arbeiten wir mit professioneller Architekturfotografie. Auch dort
          markieren wir, wenn die Bilder mit KI nachbearbeitet wurden — siehe
          Abschnitt zu den Studio-Fotos unten.
        </p>

        <h2 id="persona">Hinweis zur wiederkehrenden Klientinnen-Persona</h2>
        <p>
          Auf einigen Bildern erscheint eine wiederkehrende, ruhig portraitierte
          Klientinnen-Figur. Diese Person ist <strong>fiktiv</strong>. Sie wurde
          bewusst als KI-generiertes, konsistentes Modell erschaffen, weil das
          Bild-Konzept eine identifizierbare Klientinnen-Stimme braucht — ohne
          dass dafür eine reale Person Persönlichkeitsrechte abtreten müsste.
          Die Figur entspricht keiner real existierenden, identifizierbaren
          Person; etwaige Ähnlichkeiten sind unbeabsichtigt. Falls dir eine
          Übereinstimmung mit einer realen Person auffällt, melde dich bitte
          unter <a href={`mailto:${site.contact.email}`}>{site.contact.email}</a>
          — wir prüfen den Fall und tauschen das betreffende Bild aus.
        </p>

        <h2 id="location">Hinweis zu den Studio-Fotos</h2>
        <p>
          Die Aufnahmen unseres Hauses in der Marienstraße 58 sind originale
          Architekturfotografien eines beauftragten Fotografen. Eine dieser
          Aufnahmen wurde mit KI-Werkzeugen (Bild-Editing-Modus von Google
          Nanobanana Pro über fal.ai) leicht retuschiert — konkret wurde im
          Vordergrund eine Briefkasten-Anlage entfernt, um den Bildaussagewert
          des Hero-Bilds zu schärfen. Die übrigen Studio-Fotos sind unbearbeitet.
          Auch retuschierte Bilder tragen den „cr"-Pin, weil substanzielle
          KI-Bearbeitung nach EU AI Act ebenfalls kennzeichnungspflichtig ist.
        </p>

        <h2 id="tools">Eingesetzte Werkzeuge</h2>
        <p>
          Wir verwenden derzeit folgende KI-Bildwerkzeuge:
        </p>
        <ul>
          <li><strong>Google Nanobanana Pro</strong> (Gemini 2.5 Flash Image)
              für Bildgenerierung mit Identitäts-Referenz und Bild-Editing.</li>
          <li><strong>fal.ai</strong> als Plattform für die Modellansteuerung,
              Speicherung der temporären Outputs und Konvertierung in
              webfähige Formate.</li>
        </ul>
        <p>
          Die finalen Bild-Dateien werden lokal in unserem WebP-Format
          optimiert, bevor sie veröffentlicht werden. Die Original-JPEGs und
          die jeweils zugrunde liegenden Prompts archivieren wir intern, damit
          wir die Provenienz auch retrospektiv nachweisen können.
        </p>

        <h2 id="rechtsgrundlagen">Rechtsgrundlagen</h2>
        <p>
          Diese Kennzeichnung erfüllt:
        </p>
        <ul>
          <li><strong>EU AI Act, Art. 50 Abs. 2 und 4</strong> — Pflicht zur
              klaren, sichtbaren Kennzeichnung synthetischer oder substanziell
              KI-bearbeiteter Bildinhalte (gilt verbindlich ab 2. August 2026).</li>
          <li><strong>C2PA Content Credentials Specification 2.0</strong> —
              technischer Standard für die Provenienz-Markierung digitaler
              Inhalte; das „cr"-Pin ist die offizielle UI-Kennzeichnung.</li>
          <li><strong>UWG / Wettbewerbsrecht</strong> — Transparenz darüber,
              dass Bildinhalte synthetisch erzeugt wurden, schließt
              irreführende Werbung aus.</li>
          <li><strong>Persönlichkeitsrecht (KUG, GG Art. 2 Abs. 1 i. V. m.
              Art. 1 Abs. 1)</strong> — die fiktive Klientinnen-Persona berührt
              keine Bildrechte realer Personen; Ähnlichkeiten sind weder
              beabsichtigt noch zulässig.</li>
        </ul>

        <h2 id="kontakt">Fragen oder Beanstandungen</h2>
        <p>
          Du hast Fragen zu einem konkreten Bild, möchtest ein Bild
          beanstanden, oder vermutest eine ungewollte Ähnlichkeit mit einer
          realen Person? Schreib uns kurz an
          <a href={`mailto:${site.contact.email}`}>{site.contact.email}</a> —
          wir antworten innerhalb von 48 Stunden und nehmen Bilder im Zweifel
          umgehend vom Netz.
        </p>
      </div>
    </section>
  </article>
</BaseLayout>

<style>
  .rb-prose h1 { font-family: var(--rb-font-display); font-size: var(--rb-text-3xl); margin-bottom: 12px; }
  .rb-prose h2 { font-family: var(--rb-font-display); font-size: var(--rb-text-xl); margin: 40px 0 12px; scroll-margin-top: 96px; }
  .rb-prose p, .rb-prose li { font-family: var(--rb-font-body); line-height: var(--rb-leading-loose); color: var(--rb-ink-700); margin: 0 0 12px; }
  .rb-prose ul, .rb-prose ol { padding-left: 22px; margin: 0 0 16px; }
  .rb-prose a { color: var(--rb-gold-700); }
  .rb-prose .rb-lead {
    font-size: 18px;
    line-height: 1.6;
    color: var(--rb-ink-900);
    margin-bottom: 28px;
  }
  .rb-toc {
    background: var(--rb-cream-50, #faf6ed);
    border: 1px solid var(--rb-ink-100);
    border-radius: 8px;
    padding: 20px 24px;
    margin: 0 0 32px;
    font-size: 14px;
  }
  .rb-toc strong { display: block; margin-bottom: 8px; font-family: var(--rb-font-display); font-size: var(--rb-text-sm); letter-spacing: 0.04em; text-transform: uppercase; color: var(--rb-ink-500); }
  .rb-toc ol { margin: 0; padding-left: 22px; }
  .rb-toc li { margin: 4px 0; }
</style>
