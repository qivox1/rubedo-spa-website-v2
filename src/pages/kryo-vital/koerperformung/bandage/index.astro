---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { site } from '@/lib/site';

const title = 'Body Slimming Bandage Minden — fünf Wirkstoff-Linien';
const description = 'Wirkstoff-Bandagen für leichtere Beine — fünf Linien: Marine Salt, Slim-Cell, Warme Cell, Kryo Tonic, Flying Legs. Rubedo Spa Minden.';
const heroImage = '/images/bandage-hero.webp';
const url = `${site.url}/kryo-vital/koerperformung/bandage/`;

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  '@id': `${url}#service`,
  serviceType: 'Body Slimming Bandage',
  name: 'Body Slimming Bandage — Wirkstoff-Bandagen für die Beine',
  description: 'Mit ausgewählten Wirkstoffen getränkte Gazen, ringförmig um die Beine gelegt — fünf Linien für unterschiedliche Pflege- und Wellness-Schwerpunkte.',
  url,
  image: `${site.url}${heroImage}`,
  category: 'Wellness',
  provider: { '@id': `${site.url}/#localbusiness` },
  areaServed: { '@type': 'City', name: 'Minden' },
  offers: [
    { '@type': 'Offer', name: 'Einzelanwendung (40 Min)', price: '99', priceCurrency: 'EUR' },
    { '@type': 'Offer', name: '10er-Karte', price: '900', priceCurrency: 'EUR' },
  ],
};

const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Start', item: `${site.url}/` },
    { '@type': 'ListItem', position: 2, name: 'Kryo Vital', item: `${site.url}/kryo-vital/` },
    { '@type': 'ListItem', position: 3, name: 'Körperformung', item: `${site.url}/kryo-vital/koerperformung/` },
    { '@type': 'ListItem', position: 4, name: 'Body Slimming Bandage', item: url },
  ],
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    { '@type': 'Question', name: 'Welche Linie ist für den Einstieg geeignet?', acceptedAnswer: { '@type': 'Answer', text: 'Wenn du dir nicht sicher bist, empfehlen wir die Flying Legs Bandage — sie hat die ruhigste, breit angelegte Wirkung und passt zu fast jedem Wellness-Tag.' } },
    { '@type': 'Question', name: 'Kann ich die Bandage mit der Druckwellen-Anwendung kombinieren?', acceptedAnswer: { '@type': 'Answer', text: 'Ja. Die Kombi-Anwendung ist eines unserer beliebtesten Formate.' } },
  ],
};
---

<BaseLayout
  title={title}
  description={description}
  heroImage={heroImage}
  schemaExtras={[serviceSchema, breadcrumb, faqSchema]}
>
  <article class="rb-page" data-page="bandage">

    <!-- HERO -->
    <section class="rb-block-hero rb-block-hero--photo">
      <div class="rb-block-hero__photo">
        <img src="/images/bandage-hero.webp" alt="Body Slimming Bandage im Rubedo Spa — Wirkstoff-Bandage in burgunderfarbenem Studio-Setting" width="1600" height="900" fetchpriority="high" />
        <div class="rb-wrap">
          <div class="rb-block-hero__copy">
            <span class="rb-block-hero__eyebrow">Kryo Vital · Körperformung</span>
            <h1>Wirkstoff-Bandagen für leichtere Beine.</h1>
            <p class="rb-block-hero__subline">Fünf Bandagen-Linien — jede mit einem klaren Pflege- und Wellness-Schwerpunkt.</p>
            <div class="rb-block-hero__cta">
              <a href="/termin-buchen/#intent=bandage" class="rb-btn rb-btn--primary rb-btn--lg">Einzelanwendung · 99 €</a>
              <a href="#linien" class="rb-btn rb-btn--ghost">Linien ansehen</a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- WHAT IS A BANDAGE -->
    <section class="rb-block-imgtext rb-section--paper">
      <div class="rb-wrap">
        <div class="rb-imgtext rb-imgtext--reverse">
          <div class="rb-imgtext__media">
            <img src="/images/bandage-content-salz.webp" alt="Marine-Salt-Bandage mit Salzkristall-Detail" width="800" height="600" loading="lazy" />
          </div>
          <div class="rb-imgtext__body">
            <span class="rb-eyebrow">Was Wirkstoff-Bandagen sind</span>
            <h2>Wirkstoff-getränkte Gazen, ringförmig um die Beine.</h2>
            <p>Bandagen sind spezielle, mit ausgewählten Wirkstoffen getränkte Gazen. Sie werden ringförmig um die Beine gelegt und entwickeln in der Anwendungsphase ihren Pflege- und Wellness-Effekt.</p>
            <p>Je nach Bandagen-Linie liegt der Schwerpunkt auf einem ruhigen, leichten Hautempfinden, auf einem aktiven, frischen Eindruck oder auf einer Kombination beider. Die Anwendung ist ein <strong>Wellness-Ritual</strong> — kein medizinisches Verfahren.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- FIVE LINES -->
    <section id="linien" class="rb-section rb-section--cream">
      <div class="rb-wrap">
        <div class="rb-block-cards__head">
          <div><span class="rb-eyebrow">Unsere fünf Linien</span><h2>Eine Bandage für jede Stimmung.</h2></div>
        </div>
        <div class="rb-cards">
          <article class="rb-tcard"><div class="rb-tcard__media rb-tcard__media--mar rb-tcard__media--photo"><img src="/images/bandage-content-salz.webp" alt="Marine-Salt-Bandage mit Salzkristall-Detail" width="600" height="400" loading="lazy" /></div>
            <div class="rb-tcard__body"><div class="rb-tcard__meta"><span>40 Min</span><span>Mineralisch</span></div><h3 class="rb-tcard__title">Marine Salt</h3><p class="rb-tcard__text">Mineralisch-frische Linie. Kühler, klarer Charakter — beliebt im Sommer und an warmen Studio-Tagen.</p><div class="rb-tcard__foot"><span class="rb-tcard__price">99 €</span><a href="/termin-buchen/#intent=bandage-marine" class="rb-tcard__cta">Buchen</a></div></div></article>
          <article class="rb-tcard"><div class="rb-tcard__media rb-tcard__media--slim"><svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><circle cx="12" cy="12" r="3"/><circle cx="12" cy="12" r="9"/></svg></div>
            <div class="rb-tcard__body"><div class="rb-tcard__meta"><span>40 Min</span><span>Pflegend</span></div><h3 class="rb-tcard__title">Slim-Cell</h3><p class="rb-tcard__text">Pflegende Linie mit Schwerpunkt auf dem Empfinden von Wassereinlagerungen — ruhig und ergänzend in einem Vital-Plan.</p><div class="rb-tcard__foot"><span class="rb-tcard__price">99 €</span><a href="/termin-buchen/#intent=bandage-slim" class="rb-tcard__cta">Buchen</a></div></div></article>
          <article class="rb-tcard"><div class="rb-tcard__media rb-tcard__media--warm"><svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M12 3c0 4-4 4-4 8s4 4 4 8M16 5c0 3-3 3-3 7s3 3 3 7"/></svg></div>
            <div class="rb-tcard__body"><div class="rb-tcard__meta"><span>40 Min</span><span>Wärmend</span></div><h3 class="rb-tcard__title">Warme Cell-Effect</h3><p class="rb-tcard__text">Wärmend-aktivierende Linie. Schöne Wahl für die Wahrnehmung eines warmen, weichen Körperempfindens.</p><div class="rb-tcard__foot"><span class="rb-tcard__price">99 €</span><a href="/termin-buchen/#intent=bandage-warm" class="rb-tcard__cta">Buchen</a></div></div></article>
          <article class="rb-tcard"><div class="rb-tcard__media rb-tcard__media--kryo"><svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M12 2v20M5 5l14 14M5 19L19 5"/></svg></div>
            <div class="rb-tcard__body"><div class="rb-tcard__meta"><span>40 Min</span><span>Kühl</span></div><h3 class="rb-tcard__title">Kryo Tonic</h3><p class="rb-tcard__text">Frisch-tonisierende Linie. Verbindet das Bandagen-Ritual mit einem leichten Kälteempfinden — bewusst kühl, klar, klärend.</p><div class="rb-tcard__foot"><span class="rb-tcard__price">99 €</span><a href="/termin-buchen/#intent=bandage-kryo" class="rb-tcard__cta">Buchen</a></div></div></article>
          <article class="rb-tcard"><div class="rb-tcard__media rb-tcard__media--legs"><svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M9 3v8l-3 10M15 3v8l3 10"/></svg></div>
            <div class="rb-tcard__body"><div class="rb-tcard__meta"><span>40 Min</span><span>Klassiker</span></div><h3 class="rb-tcard__title">Flying Legs <span style="font-weight: normal; font-size: 12px; color: var(--rb-gold-700); margin-left: 6px;">empfohlen</span></h3><p class="rb-tcard__text">Klassische Linie für müde wahrgenommene Beine. Beliebt nach langen Stunden auf den Füßen oder nach Reisen — ideal für den Einstieg.</p><div class="rb-tcard__foot"><span class="rb-tcard__price">99 €</span><a href="/termin-buchen/#intent=bandage-flying" class="rb-tcard__cta">Buchen</a></div></div></article>
        </div>
      </div>
    </section>

    <!-- PRICING -->
    <section id="preise" class="rb-block-pricing">
      <div class="rb-wrap">
        <div class="rb-pricing__head"><span class="rb-eyebrow">Konditionen</span><h2>Preise &amp; Karten.</h2></div>
        <div class="rb-pricing-tables">
          <div class="rb-pricing-table">
            <h3>Bandagen-Anwendung</h3>
            <p class="rb-pricing-table__caption">40 Min · Beine · gilt für jede der fünf Linien</p>
            <ul class="rb-pricing-rows">
              <li class="is-highlight"><span>Einzelanwendung <span class="rb-pricing-rows__badge">empfohlen</span></span><span class="rb-pricing-rows__price">99 €</span></li>
              <li><span>10er-Karte</span><span class="rb-pricing-rows__price">900 €</span></li>
            </ul>
          </div>
          <div class="rb-pricing-table">
            <h3>Kombi · Druckwellen + Bandage</h3>
            <p class="rb-pricing-table__caption">60 Min · Bandage in Kombination mit der <a href="/kryo-vital/koerperformung/">Druckwellen-Anwendung</a></p>
            <ul class="rb-pricing-rows">
              <li><span>Einzelanwendung</span><span class="rb-pricing-rows__price">220 €</span></li>
              <li><span>5er-Karte</span><span class="rb-pricing-rows__price">1.075 €</span></li>
              <li><span>10er-Karte</span><span class="rb-pricing-rows__price">2.000 €</span></li>
            </ul>
          </div>
        </div>
        <p class="rb-pricing-table__caption" style="text-align:center; margin-top:24px;">Alle Preise inkl. MwSt.</p>
      </div>
    </section>

    <!-- SUITABLE / NOT SUITABLE -->
    <section class="rb-block-duo rb-section--cream">
      <div class="rb-wrap">
        <div class="rb-duo">
          <div class="rb-duo__panel rb-duo__panel--check">
            <h3>Wann eine Bandagen-Anwendung passt</h3>
            <ul>
              <li>Nach langen Stunden auf den Füßen oder nach Reisen.</li>
              <li>Im Sommer als kühles, klares Wellness-Ritual (Marine Salt, Kryo Tonic).</li>
              <li>Als Bestandteil einer Bein-Vitalitäts- oder Körperformungs-Routine.</li>
              <li>In Kombination mit der Druckwellen-Anwendung — als Kombi-Format.</li>
            </ul>
          </div>
          <div class="rb-duo__panel rb-duo__panel--cross">
            <h3>Wann sie nicht für dich passt</h3>
            <ul>
              <li>Bei akuten Gefäßerkrankungen oder Thrombose-Verdacht.</li>
              <li>Bei akuten Hautinfektionen oder offenen Wunden im Anwendungsbereich.</li>
              <li>In der Schwangerschaft — bitte vorher ärztlich abklären lassen.</li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="rb-block-faq">
      <div class="rb-wrap">
        <div class="rb-faq__head">
          <div><span class="rb-eyebrow">FAQ · Bandage</span><h2>Häufige Fragen.</h2></div>
          <p>Wenn du unsicher bist, welche Linie zu dir passt — wir beraten dich beim Aufnahme-Gespräch.</p>
        </div>
        <ul class="rb-faq-list">
          <li><details class="rb-faq-item" open><summary>Welche Linie ist für den Einstieg geeignet?</summary><div class="rb-faq-item__body">Wenn du dir nicht sicher bist, empfehlen wir die Flying Legs Bandage — sie hat die ruhigste, breit angelegte Wirkung und passt zu fast jedem Wellness-Tag.</div></details></li>
          <li><details class="rb-faq-item"><summary>Kann ich die Bandage mit der Druckwellen-Anwendung kombinieren?</summary><div class="rb-faq-item__body">Ja. Die Kombi-Anwendung ist eines unserer beliebtesten Formate. Details findest du im Abschnitt <a href="#preise">Preise</a>.</div></details></li>
        </ul>
      </div>
    </section>

    <section class="rb-block-cta-whisper">
      <div class="rb-wrap">
        <aside class="rb-cta-whisper" aria-label="Kostenfreies 15-Minuten-Erstgespräch">
          <span class="rb-cta-whisper__eyebrow">15-Min-Videoberatung</span>
          <h3>Ist Body Slimming Bandage die richtige Wahl?</h3>
          <p>Bandage oder Wrap — der Unterschied liegt im Detail. Im kurzen Videocall mit Monica finden wir gemeinsam heraus, was zu dir passt.</p>
          <a class="rb-cta-whisper__link" href="/termin-buchen/">Erstgespräch mit Monica buchen</a>
          <span class="rb-cta-whisper__meta">Kostenfrei · 15 Minuten · Online via Videocall</span>
        </aside>
      </div>
    </section>

  </article>
</BaseLayout>
