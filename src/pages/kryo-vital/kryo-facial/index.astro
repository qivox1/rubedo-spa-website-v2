---
import BaseLayout from '@/layouts/BaseLayout.astro';
import MagazinTeaser from '@/components/MagazinTeaser.astro';
import { site } from '@/lib/site';

const title = 'Kryo-Facial Minden — Kältepflege für klare Haut | Rubedo Spa';
const description = 'Vier Kryo-Facial-Linien für klares Hautbild, Antioxidantien und Tiefenwirkung. Rubedo Spa Minden — Termin online buchen.';
const heroImage = '/images/kryo-vital-content-nach.webp';
const url = `${site.url}/kryo-vital/kryo-facial/`;

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  '@id': `${url}#service`,
  name: 'Kryo-Facial — Kältepflege für das Gesicht',
  serviceType: 'Beauty Service',
  description: 'Kryo-Facial kombiniert kontrollierten Kältereiz mit abgestimmten Wirkstoffen — vier Linien (Beauty Antioxidant, Plus Intensiv, Express, Quick), je nach Hautbedürfnis gewählt.',
  provider: { '@id': `${site.url}/#localbusiness` },
  areaServed: [
    { '@type': 'City', name: 'Minden' },
    { '@type': 'AdministrativeArea', name: 'Ostwestfalen-Lippe' },
  ],
  url,
  image: `${site.url}${heroImage}`,
  offers: {
    '@type': 'AggregateOffer',
    priceCurrency: 'EUR',
    lowPrice: '39',
    highPrice: '119',
    offerCount: '4',
    url,
  },
};

const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Start', item: `${site.url}/` },
    { '@type': 'ListItem', position: 2, name: 'Kryo Vital', item: `${site.url}/kryo-vital/` },
    { '@type': 'ListItem', position: 3, name: 'Kryo-Facial', item: url },
  ],
};
---

<BaseLayout
  title={title}
  description={description}
  heroImage={heroImage}
  schemaExtras={[serviceSchema, breadcrumb]}
>
  <article class="rb-page" data-page="kryo-facial">

    <!-- HERO -->
    <section class="rb-block-hero rb-block-hero--photo">
      <div class="rb-block-hero__photo">
        <img src={heroImage} alt="Kryo-Facial im Rubedo Spa Minden — gepflegte Haut mit warmer Lichtreflexion nach der Kälteanwendung" width="1600" height="900" fetchpriority="high" />
        <div class="rb-wrap">
          <div class="rb-block-hero__copy">
            <span class="rb-block-hero__eyebrow">Säule 02 · Kryo Vital</span>
            <h1>Kältepflege für das Gesicht. Präzise, intensiv, sichtbar.</h1>
            <p class="rb-block-hero__subline">Kryo-Facial kombiniert kontrollierten Kältereiz mit abgestimmten Wirkstoffen — vier Linien, eine Methode, je nach Hautbedürfnis gewählt.</p>
            <div class="rb-block-hero__cta">
              <a href="/termin-buchen/#intent=kryo-facial" class="rb-btn rb-btn--primary rb-btn--lg">Kryo-Facial anfragen</a>
              <a href="#linien" class="rb-btn rb-btn--ghost">Die vier Linien</a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- SECTION 1 — Die vier Linien -->
    <section id="linien" class="rb-section rb-section--cream">
      <div class="rb-wrap">
        <div class="rb-block-cards__head">
          <div><span class="rb-eyebrow">Vier Linien</span><h2>Eine Methode, vier Intensitäten.</h2></div>
        </div>
        <div class="rb-cards rb-cards--four">
          <article class="rb-tcard">
            <div class="rb-tcard__body">
              <div class="rb-tcard__meta"><span>45 Min</span><span>Beauty</span></div>
              <h3 class="rb-tcard__title">Beauty Antioxidant</h3>
              <p class="rb-tcard__text">Konzentrierter Schutz vor freien Radikalen. Ideal für Menschen mit oxidativem Stress im DNA-Profil oder empfindlichem Hautbild. Antioxidative Wirkstoffe, Kältereiz zur Gefäßaktivierung.</p>
              <div class="rb-tcard__foot"><span class="rb-tcard__price">ab 89 €</span><a href="/termin-buchen/#intent=kryo-facial" class="rb-tcard__cta">Anfragen</a></div>
            </div>
          </article>
          <article class="rb-tcard">
            <div class="rb-tcard__body">
              <div class="rb-tcard__meta"><span>60 Min</span><span>Plus</span></div>
              <h3 class="rb-tcard__title">Plus Intensiv</h3>
              <p class="rb-tcard__text">Die intensive Linie für Haut, die mehr Tiefenwirkung braucht. Hyaluron-Support, Kältereiz über längere Zeitsequenz, abschließende Wirkkomplex-Pflege.</p>
              <div class="rb-tcard__foot"><span class="rb-tcard__price">ab 119 €</span><a href="/termin-buchen/#intent=kryo-facial" class="rb-tcard__cta">Anfragen</a></div>
            </div>
          </article>
          <article class="rb-tcard">
            <div class="rb-tcard__body">
              <div class="rb-tcard__meta"><span>25 Min</span><span>Express</span></div>
              <h3 class="rb-tcard__title">Express</h3>
              <p class="rb-tcard__text">Für Gäste mit wenig Zeit, klarem Fokus. Kältereiz + leichte Wirkstoffpflege — ideal als Ergänzung zur Ganzkörper-Kryo.</p>
              <div class="rb-tcard__foot"><span class="rb-tcard__price">ab 59 €</span><a href="/termin-buchen/#intent=kryo-facial" class="rb-tcard__cta">Anfragen</a></div>
            </div>
          </article>
          <article class="rb-tcard">
            <div class="rb-tcard__body">
              <div class="rb-tcard__meta"><span>15 Min</span><span>Quick</span></div>
              <h3 class="rb-tcard__title">Quick</h3>
              <p class="rb-tcard__text">Ein gezielter Kältemoment für Gesicht und Augenpartie. Aufweckend, klärend, ohne weitere Pflege.</p>
              <div class="rb-tcard__foot"><span class="rb-tcard__price">ab 39 €</span><a href="/termin-buchen/#intent=kryo-facial" class="rb-tcard__cta">Anfragen</a></div>
            </div>
          </article>
        </div>
        <p class="rb-pricing-table__caption" style="text-align:center; margin-top:24px;">Alle Preise inkl. MwSt.</p>
      </div>
    </section>

    <!-- SECTION 2 — Für wen geeignet -->
    <section class="rb-block-prose rb-section--paper">
      <div class="rb-wrap rb-prose">
        <span class="rb-eyebrow">Für wen ist Kryo-Facial geeignet?</span>
        <h2>Ein klarer Impuls — als Teil einer bewussten Pflegeroutine.</h2>
        <p>Kryo-Facial ist ein Wellness-Angebot für Menschen, die ihrem Gesicht einen klaren Impuls geben möchten — nicht als medizinische Behandlung, sondern als Teil einer bewussten Pflegeroutine. Besonders passend als Ergänzung zum <a href="/dna-skin-intelligence/">DNA Skin Intelligence</a>-Programm, wenn das genetische Profil erhöhten oxidativen Stress oder verlangsamte Regeneration zeigt.</p>
        <p>Wer den Kältereiz auf den ganzen Körper ausweiten möchte, kombiniert das Facial mit der <a href="/kryo-vital/ganzkoerper/">Ganzkörper-Kryotherapie</a> — beide folgen demselben Prinzip des kontrollierten Reizes.</p>
      </div>
    </section>

    <!-- INCI / Inhaltsstoffe -->
    <section class="rb-section rb-section--cream">
      <div class="rb-wrap rb-wrap--narrow">
        <div class="rb-inci-note" style="padding:28px 32px; border:1px solid var(--rb-ink-100); border-radius:var(--rb-radius-lg, 16px); background:var(--rb-paper, #fff);">
          <h3 style="font-family:var(--rb-font-display); font-size:22px; font-weight:400; margin:0 0 12px;">Verwendete Produkte &amp; Inhaltsstoffe</h3>
          <p style="font-family:var(--rb-font-body); line-height:1.7; color:var(--rb-ink-700); margin:0;">Beim Kryo-Facial setzen wir je nach Linie (Beauty Antioxidant, Plus Intensiv, Express, Quick) professionelle Wirkstoffe aus der Kosmetologie ein. Die vollständige INCI-Liste der verwendeten Produkte ist auf Anfrage erhältlich: <a href={`mailto:${site.contact.email}`} style="color:var(--rb-gold-700);">{site.contact.email}</a>. Alle eingesetzten Produkte entsprechen der EU-Kosmetikverordnung (EG) Nr. 1223/2009 und werden ausschließlich von zertifizierten Lieferanten bezogen.</p>
        </div>
      </div>
    </section>

    <!-- DISCLAIMER -->
    <section class="rb-block-disclaimer">
      <div class="rb-wrap rb-wrap--narrow">
        <div class="rb-disclaimer">
          <div class="rb-disclaimer__icon"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"><circle cx="12" cy="12" r="9"/><path d="M12 8v5M12 16v.01"/></svg></div>
          <div>
            <h3>Hinweis zur Wirkung</h3>
            <p>Kryo-Facial ist eine Wellness-Anwendung. Wir machen keine Heilversprechen und keine Wirkaussagen im medizinischen Sinne. Beschriebene Wahrnehmungen (klarer, frischer, belebter) sind subjektive Gasterfahrungen.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="rb-block-cta">
      <div class="rb-wrap">
        <div class="rb-cta-band">
          <div class="rb-cta-band__body">
            <span class="rb-eyebrow">Termin</span>
            <h3>Welche Linie passt zu deiner Haut?</h3>
            <p>Wir empfehlen die passende Kryo-Facial-Linie im kurzen Gespräch — auf Wunsch abgestimmt auf dein DNA-Skin-Profil.</p>
          </div>
          <div class="rb-cta-band__action"><a class="rb-btn--ghost-light" href="/termin-buchen/#intent=kryo-facial">Kryo-Facial anfragen →</a></div>
        </div>
      </div>
    </section>

    <MagazinTeaser
      tags={["kryo-vital", "kryotherapie", "kryotherapie-minden", "drei-saeulen", "hautpflege"]}
      heading="Aus dem Magazin"
      eyebrow="Vertiefen"
      intro="Hintergründe zu kontrolliertem Kältereiz und Hautpflege — verfasst von Monica Galletti."
      variant="paper"
    />

  </article>
</BaseLayout>
