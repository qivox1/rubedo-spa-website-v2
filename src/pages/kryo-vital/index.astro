---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { site } from '@/lib/site';

const title = 'Kryotherapie Minden — Kryo Vital bei Monica Galletti';
const description = 'Drei Minuten Kälte bei −110 °C. Ganzkörper-Kryo, Druckwellen & Bandagen im Rubedo Spa Minden bei Monica Galletti — Termin online buchen.';
const heroImage = '/images/kryo-vital-hero.webp';
const url = `${site.url}/kryo-vital/`;

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  '@id': `${url}#service`,
  name: 'Kryo Vital — Kryotherapie & Wellness-Anwendungen',
  serviceType: 'Wellness Service',
  description: 'Kontrollierte Kälte als Wellness-Reiz: Ganzkörper-Kryotherapie bei −110 °C, Druckwellen, Body-Wraps mit Botanicals und Wirkstoff-Bandagen.',
  provider: { '@id': `${site.url}/#localbusiness` },
  areaServed: [
    { '@type': 'City', name: 'Minden' },
    { '@type': 'AdministrativeArea', name: 'Ostwestfalen-Lippe' },
  ],
  url,
  image: `${site.url}${heroImage}`,
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  '@id': `${url}#faq`,
  mainEntity: [
    { '@type': 'Question', name: 'Wie kalt wird es wirklich?', acceptedAnswer: { '@type': 'Answer', text: 'In der Ganzkörper-Anwendung erreichen wir eine Lufttemperatur von etwa minus 110 °C. Dein Körperinneres bleibt davon weitgehend unberührt; die Reaktion entsteht über die Haut und das Nervensystem.' } },
    { '@type': 'Question', name: 'Friert man dabei?', acceptedAnswer: { '@type': 'Answer', text: 'Die Kälte ist trocken und für viele Gäste erstaunlich gut auszuhalten. Drei Minuten sind kürzer, als sie klingen — und das Gefühl danach ist meist energetisch warm.' } },
    { '@type': 'Question', name: 'Wie oft kann ich Kryo nutzen?', acceptedAnswer: { '@type': 'Answer', text: 'Vom einzelnen Termin pro Monat bis zu mehreren Anwendungen pro Woche ist alles möglich. Wir empfehlen für den Einstieg ein 4er-Testpaket, um zu spüren, wie dein Körper reagiert.' } },
    { '@type': 'Question', name: 'Kann ich Kryo mit anderen Behandlungen kombinieren?', acceptedAnswer: { '@type': 'Answer', text: 'Ja. Beliebte Kombinationen sind Kryo + Druckwellen-Anwendung oder Kryo + Massage in der Rubedo Suite. Bei Bedarf gestalten wir dir ein individuelles Vital-Paket.' } },
  ],
};
---

<BaseLayout
  title={title}
  description={description}
  heroImage={heroImage}
  schemaExtras={[serviceSchema, faqSchema]}
>

  <article class="rb-page" data-page='kryo-vital'>
    <section class="rb-block-hero rb-block-hero--photo">
        <div class="rb-block-hero__photo">
          <img src="/images/kryo-vital-hero.webp" alt="Kryo-Suite im Rubedo Spa Minden — Eingang mit Eis-Reflexion und burgunder Robe" width="1600" height="900" fetchpriority="high" />
          <div class="rb-wrap">
            <div class="rb-block-hero__copy">
              <span class="rb-block-hero__eyebrow">Säule 02 · Aktivierung</span>
              <h1>Kälte als bewusster Reiz für Vitalität.</h1>
              <p class="rb-block-hero__subline">Drei Minuten kontrollierte Kälte. Eine Welle aus Wachheit, Energie und Erholung.</p>
              <div class="rb-block-hero__cta">
                <a href="/kryo-vital/ganzkoerper/" class="rb-btn rb-btn--primary rb-btn--lg">Ganzkörper-Kryo · ab 50 €</a>
                <a href="#anwendungen" class="rb-btn rb-btn--ghost">Anwendungen ansehen</a>
              </div>
            </div>
          </div>
        </div>
      </section>

      <section class="rb-block-imgtext rb-section--paper">
        <div class="rb-wrap">
          <div class="rb-imgtext rb-imgtext--reverse">
            <div class="rb-imgtext__media">
              <img src="/images/kryo-vital-content-eis.webp" alt="Eis-Kristalle nah, Atemkondensation auf dunklem Hintergrund" width="800" height="600" loading="lazy" />
            </div>
            <div class="rb-imgtext__body">
              <span class="rb-eyebrow">Was Kryo bei Rubedo bedeutet</span>
              <h2>Wellness-Reiz, keine Therapie.</h2>
              <p>Kryotherapie heißt wörtlich „Kältetherapie" — und auch wenn der Name medizinisch klingt, ist die Ganzkörper-Anwendung bei Rubedo eine <strong>Wellness-Erfahrung</strong>. Du betrittst eine Kryo-Suite, in der die Lufttemperatur für drei Minuten auf bis zu minus 110 °C abgesenkt wird. Dein Körper erlebt einen kurzen, intensiven Kältereiz — und reagiert mit einer Aktivierung, die viele Gäste als „Wachwerden auf einer ganz neuen Ebene" beschreiben.</p>
              <p>Wir setzen Kryo nicht als Therapie ein. Wir setzen sie als Wellness-Reiz ein, der dem Körper hilft, in seine eigenen Regenerationsprozesse zurückzufinden — und der sich gut mit deinem Alltag, deinem Sport oder deiner Pflege-Routine verbinden lässt.</p>
            </div>
          </div>
        </div>
      </section>

      <!-- 4 Anwendungen -->
      <section id="anwendungen" class="rb-section rb-section--cream">
        <div class="rb-wrap">
          <div class="rb-block-cards__head">
            <div><span class="rb-eyebrow">Unsere Anwendungen</span><h2>Vier Wege, Kälte einzusetzen.</h2></div>
          </div>
          <div class="rb-cards rb-cards--four">
            <article class="rb-tcard">
              <div class="rb-tcard__media rb-tcard__media--kryo rb-tcard__media--photo"><img src="/images/kryo-ganzkoerper-hero.webp" alt="Ganzkörper-Kryo-Kabine mit Eis-Reflexion im Rubedo Spa" width="600" height="400" loading="lazy" /></div>
              <div class="rb-tcard__body">
                <div class="rb-tcard__meta"><span>15 Min</span><span>−110 °C</span></div>
                <h3 class="rb-tcard__title">Kryo-Suite (Ganzkörper)</h3>
                <p class="rb-tcard__text">Drei Minuten in der Ein-Personen-Kabine. Anschließend Bewegungssequenz zur Kreislauf-Aktivierung.</p>
                <div class="rb-tcard__foot"><span class="rb-tcard__price">50 €<small>/ Anwendung</small></span><a href="/kryo-vital/ganzkoerper/" class="rb-tcard__cta">Ganzkörper-Kryo ansehen</a></div>
              </div>
            </article>
            <article class="rb-tcard">
              <div class="rb-tcard__media rb-tcard__media--kryo"><svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><circle cx="12" cy="12" r="6"/><path d="M12 3v3M12 18v3M3 12h3M18 12h3"/></svg></div>
              <div class="rb-tcard__body">
                <div class="rb-tcard__meta"><span>15 Min</span><span>Lokal</span></div>
                <h3 class="rb-tcard__title">Kryo-Lokal</h3>
                <p class="rb-tcard__text">Gezielte Kälteanwendung an einer einzelnen Körperzone — wirkt auf Gewebegefühl und Verspannungswahrnehmung.</p>
                <div class="rb-tcard__foot"><span class="rb-tcard__price">36 €<small>/ Anwendung</small></span><a href="/kryo-vital/ganzkoerper/#preise" class="rb-tcard__cta">Kryo-Lokal-Preise ansehen</a></div>
              </div>
            </article>
            <article class="rb-tcard">
              <div class="rb-tcard__media rb-tcard__media--mar rb-tcard__media--photo"><img src="/images/druckwellen-hero.webp" alt="Druckwellen-Manschette mit Aubergine-Akzent" width="600" height="400" loading="lazy" /></div>
              <div class="rb-tcard__body">
                <div class="rb-tcard__meta"><span>40 Min</span><span>Shaping</span></div>
                <h3 class="rb-tcard__title">Körperformung &amp; Druckwellen</h3>
                <p class="rb-tcard__text">Druckwellen-Anwendung, Wraps und Bandagen — Kompressions-Wellness für Beine, Bauch und Arme.</p>
                <div class="rb-tcard__foot"><span class="rb-tcard__price">ab 45 €</span><a href="/kryo-vital/koerperformung/" class="rb-tcard__cta">Körperformung ansehen</a></div>
              </div>
            </article>
            <article class="rb-tcard">
              <div class="rb-tcard__media rb-tcard__media--wrap rb-tcard__media--photo"><img src="/images/kryo-vital-content-nach.webp" alt="Gepflegte Haut nach Kryo-Facial mit warmer Lichtreflexion" width="600" height="400" loading="lazy" /></div>
              <div class="rb-tcard__body">
                <div class="rb-tcard__meta"><span>4 Linien</span><span>Facial</span></div>
                <h3 class="rb-tcard__title">Kryo-Facial</h3>
                <p class="rb-tcard__text">Kälte trifft Hautpflege. Vier Linien: Beauty (Anti-Oxidant), Plus (intensiv), Express und Quick.</p>
                <div class="rb-tcard__foot"><span class="rb-tcard__price">ab 89 €</span><a href="/termin-buchen/#intent=kryo-facial" class="rb-tcard__cta">Anfragen</a></div>
              </div>
            </article>
          </div>
        </div>
      </section>

      <section class="rb-block-cta-whisper">
        <div class="rb-wrap">
          <aside class="rb-cta-whisper" aria-label="Kostenfreies 15-Minuten-Erstgespräch">
            <span class="rb-cta-whisper__eyebrow">15-Min-Videoberatung</span>
            <h3>Welche Kryo-Anwendung passt zu dir?</h3>
            <p>Im kurzen Videocall klären wir gemeinsam, ob Ganzkörper, Facial oder eine Kombination der richtige Einstieg für dich ist — ohne Verpflichtung.</p>
            <a class="rb-cta-whisper__link" href="/termin-buchen/">Erstgespräch mit Monica buchen</a>
            <span class="rb-cta-whisper__meta">Kostenfrei · 15 Minuten · Online via Videocall</span>
          </aside>
        </div>
      </section>

      <!-- Körperformung Bridge -->
      <section class="rb-block-prose rb-section--paper">
        <div class="rb-wrap rb-prose">
          <span class="rb-eyebrow">Körperformung & Bein-Vitalität</span>
          <h2>Ergänzende Anwendungen ohne Kabine.</h2>
          <p>Wir bündeln unter Kryo Vital auch jene Anwendungen, die ohne Kabine arbeiten, aber demselben Prinzip folgen: kontrollierte Reize, die deinem Körper helfen, sich aktiver, leichter und klarer zu fühlen.</p>
          <ul>
            <li><strong><a href="/kryo-vital/koerperformung/">Druckwellen-Anwendung</a></strong> — Kompressions-Wellness für Beine, Bauch und Arme.</li>
            <li><strong><a href="/kryo-vital/koerperformung/wrap/">Body Slimming Wraps</a></strong> — Wickel-Anwendungen für ein gepflegtes Hautbild, drei Linien: Total, Fast, Silhouette.</li>
            <li><strong><a href="/kryo-vital/koerperformung/bandage/">Body Slimming Bandagen</a></strong> — fünf Linien: Marine Salt, Slim-Cell, Warme Cell, Kryo Tonic, Flying Legs.</li>
          </ul>
        </div>
      </section>

      <!-- Geeignet / Ausschlüsse -->
      <section class="rb-block-duo rb-section--cream">
        <div class="rb-wrap">
          <div class="rb-duo">
            <div class="rb-duo__panel rb-duo__panel--check">
              <h3>Wann Kryo besonders sinnvoll ist</h3>
              <ul>
                <li>Vor und nach sportlichen Belastungen — als Beitrag zur empfundenen Erholung.</li>
                <li>Als bewusster Wachimpuls in Phasen mit langen Bildschirm-Tagen.</li>
                <li>Als Bestandteil einer Wellness-Routine — etwa wöchentlich kombiniert mit einer Massage.</li>
                <li>Im Rahmen einer DNA-Skin-Routine als Vitalitäts-Impuls.</li>
              </ul>
            </div>
            <div class="rb-duo__panel rb-duo__panel--cross">
              <h3>Wann Kryo nicht für dich geeignet ist</h3>
              <ul>
                <li>Unbehandelter Bluthochdruck oder schwere Herz-Kreislauf-Erkrankungen.</li>
                <li>Schwere Erkrankungen der Atemwege.</li>
                <li>Schwangerschaft.</li>
                <li>Offene Wunden, akute Hauterkrankungen oder Kälteallergien.</li>
                <li>Künstliche Herzklappen, bestimmte Schrittmacher und Implantate.</li>
              </ul>
            </div>
          </div>
          <p style="margin: 32px auto 0; max-width: 720px; text-align:center; font-size: 14px; color: var(--rb-ink-500); line-height: 1.65;">Vor deiner ersten Anwendung erhältst du einen Anamnese-Bogen. Wir besprechen mit dir gemeinsam, ob die Anwendung für dich passt — und im Zweifel verweisen wir an deine Hausärztin oder deinen Hausarzt.</p>
        </div>
      </section>

      <!-- Pricing -->
      <section class="rb-block-pricing">
        <div class="rb-wrap">
          <div class="rb-pricing__head"><span class="rb-eyebrow">Konditionen</span><h2>Preise & Karten.</h2></div>
          <div class="rb-pricing-tables">
            <div class="rb-pricing-table">
              <h3>Kryo-Suite — Ganzkörper</h3>
              <p class="rb-pricing-table__caption">15-Min-Termin · 3 Min in der Kabine</p>
              <ul class="rb-pricing-rows">
                <li><span>Einzelanwendung</span><span class="rb-pricing-rows__price">50 €</span></li>
                <li class="is-highlight"><span>4er-Testpaket <span class="rb-pricing-rows__badge">empfohlen</span></span><span class="rb-pricing-rows__price">160 €</span></li>
                <li><span>5er-Karte</span><span class="rb-pricing-rows__price">230 €</span></li>
                <li><span>10er-Karte</span><span class="rb-pricing-rows__price">450 €</span></li>
              </ul>
            </div>
            <div class="rb-pricing-table">
              <h3>Kryo-Lokal — gezielt</h3>
              <p class="rb-pricing-table__caption">15 Min · einzelne Körperzone</p>
              <ul class="rb-pricing-rows">
                <li><span>Einzelanwendung</span><span class="rb-pricing-rows__price">36 €</span></li>
                <li><span>5er-Karte</span><span class="rb-pricing-rows__price">165 €</span></li>
                <li><span>10er-Karte</span><span class="rb-pricing-rows__price">320 €</span></li>
              </ul>
            </div>
          </div>
        </div>
      </section>

      <section class="rb-block-faq">
        <div class="rb-wrap">
          <div class="rb-faq__head">
            <div><span class="rb-eyebrow">FAQ · Kryo Vital</span><h2>Häufige Fragen.</h2></div>
            <p>Drei Minuten klingen kurz — und werfen erfahrungsgemäß die meisten Fragen vorher auf.</p>
          </div>
          <ul class="rb-faq-list">
            <li><details class="rb-faq-item" open><summary>Wie kalt wird es wirklich?</summary><div class="rb-faq-item__body">In der Ganzkörper-Anwendung erreichen wir eine Lufttemperatur von etwa minus 110 °C. Dein Körperinneres bleibt davon weitgehend unberührt; die Reaktion entsteht über die Haut und das Nervensystem.</div></details></li>
            <li><details class="rb-faq-item"><summary>Friert man dabei?</summary><div class="rb-faq-item__body">Die Kälte ist trocken und für viele Gäste erstaunlich gut auszuhalten. Drei Minuten sind kürzer, als sie klingen — und das Gefühl danach ist meist energetisch warm.</div></details></li>
            <li><details class="rb-faq-item"><summary>Wie oft kann ich Kryo nutzen?</summary><div class="rb-faq-item__body">Vom einzelnen Termin pro Monat bis zu mehreren Anwendungen pro Woche ist alles möglich. Wir empfehlen für den Einstieg ein 4er-Testpaket, um zu spüren, wie dein Körper reagiert.</div></details></li>
            <li><details class="rb-faq-item"><summary>Kann ich Kryo mit anderen Behandlungen kombinieren?</summary><div class="rb-faq-item__body">Ja. Beliebte Kombinationen sind Kryo + Druckwellen-Anwendung oder Kryo + Massage in der Rubedo Suite. Bei Bedarf gestalten wir dir ein individuelles Vital-Paket.</div></details></li>
          </ul>
        </div>
      </section>

      <section class="rb-block-cross-pillars">
        <div class="rb-wrap">
          <div class="rb-cross-pillars">
            <span class="rb-cross-pillars__eyebrow">Weiter ergründen</span>
            <ul class="rb-cross-pillars__list">
              <li><a href="/dna-skin-intelligence/">DNA Skin Intelligence</a></li>
              <li><a href="/inner-source/">Inner Source Rituals</a></li>
            </ul>
          </div>
        </div>
      </section>

      <section class="rb-block-disclaimer">
        <div class="rb-wrap rb-wrap--narrow">
          <div class="rb-disclaimer">
            <div class="rb-disclaimer__icon"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"><circle cx="12" cy="12" r="9"/><path d="M12 8v5M12 16v.01"/></svg></div>
            <div>
              <h3>Hinweis zur Wirkung</h3>
              <p>Die Kryotherapie wird im Rubedo Spa als Wellness-Anwendung angeboten. Wir machen keine medizinischen Heilversprechen. Empfindungen wie „erfrischend" oder „belebend" sind subjektive Wahrnehmungen, die von Gästen geschildert werden.</p>
            </div>
          </div>
        </div>
      </section>

    </article>

    <!-- ============================================================
         PAGE 5 · INNER SOURCE (Hub)
         URL: /inner-source/
         ============================================================ -->
  </article>

</BaseLayout>
