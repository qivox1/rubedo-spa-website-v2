---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { site } from '@/lib/site';

const title = 'Ganzkörper-Kryotherapie Minden — Kryo-Suite · Rubedo Spa';
const description = 'Drei Minuten kontrollierte Kälte bei minus 110 °C — Ganzkörper-Kryotherapie als Wellness-Reiz im Rubedo Spa Minden. Anwendungsbereiche, Ausschlüsse, Preise.';
const heroImage = '/images/kryo-ganzkoerper-hero.webp';
const url = `${site.url}/kryo-vital/ganzkoerper/`;

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  '@id': `${url}#service`,
  serviceType: 'Ganzkörper-Kryotherapie',
  name: 'Ganzkörper-Kryotherapie (Kryo-Suite)',
  description: 'Drei Minuten kontrollierte Lufttemperatur bei bis zu −110 °C in einer Ein-Personen-Kryo-Kabine, anschließend kurze Bewegungssequenz zur Kreislauf-Aktivierung.',
  url,
  image: `${site.url}${heroImage}`,
  category: 'Wellness',
  provider: { '@id': `${site.url}/#localbusiness` },
  areaServed: { '@type': 'City', name: 'Minden' },
  offers: [
    { '@type': 'Offer', name: 'Einzelanwendung', price: '50', priceCurrency: 'EUR' },
    { '@type': 'Offer', name: '4er-Testpaket (einmalig pro Person)', price: '160', priceCurrency: 'EUR' },
    { '@type': 'Offer', name: '5er-Karte', price: '230', priceCurrency: 'EUR' },
    { '@type': 'Offer', name: '10er-Karte', price: '450', priceCurrency: 'EUR' },
  ],
};

const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Start', item: `${site.url}/` },
    { '@type': 'ListItem', position: 2, name: 'Kryo Vital', item: `${site.url}/kryo-vital/` },
    { '@type': 'ListItem', position: 3, name: 'Ganzkörper-Kryotherapie', item: url },
  ],
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    { '@type': 'Question', name: 'Tut die Kälte weh?', acceptedAnswer: { '@type': 'Answer', text: 'Nein. Die Kälte ist trocken und unangenehmer in der Vorstellung als in der Erfahrung. Die meisten Gäste sind nach den drei Minuten überrascht, wie kurz die Anwendung gefühlt war.' } },
    { '@type': 'Question', name: 'Was ziehe ich an?', acceptedAnswer: { '@type': 'Answer', text: 'Wellness-Unterwäsche oder Sportbekleidung. Handschuhe, Socken und Mundschutz stellen wir.' } },
    { '@type': 'Question', name: 'Wie schnell merke ich etwas?', acceptedAnswer: { '@type': 'Answer', text: 'Die meisten Gäste berichten unmittelbar nach der Anwendung von einem klaren, energetischen Empfinden. Manche merken stärkere Effekte erst nach drei bis vier Anwendungen — daher der Sinn des 4er-Testpakets.' } },
  ],
};
---

<BaseLayout
  title={title}
  description={description}
  heroImage={heroImage}
  schemaExtras={[serviceSchema, breadcrumb, faqSchema]}
>
  <article class="rb-page" data-page="kryo-ganzkoerper">

    <!-- HERO -->
    <section class="rb-block-hero rb-block-hero--photo">
      <div class="rb-block-hero__photo">
        <img src="/images/kryo-ganzkoerper-hero.webp" alt="Ganzkörper-Kryo-Kabine im Rubedo Spa — Eis-Reflexion auf gebürstetem Edelstahl" width="1600" height="900" fetchpriority="high" />
        <div class="rb-wrap">
          <div class="rb-block-hero__copy">
            <span class="rb-block-hero__eyebrow">Kryo Vital · Ganzkörper</span>
            <h1>Drei Minuten Kälte. Eine Welle Vitalität.</h1>
            <p class="rb-block-hero__subline">Ganzkörper-Kryotherapie im Herzen von Minden — als Wellness-Reiz für deinen Körper.</p>
            <div class="rb-block-hero__cta">
              <a href="/termin-buchen/?intent=kryo-suite" class="rb-btn rb-btn--primary rb-btn--lg">4er-Testpaket · 160 €</a>
              <a href="#preise" class="rb-btn rb-btn--ghost">Preise ansehen</a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- WHAT HAPPENS -->
    <section class="rb-block-imgtext rb-section--paper">
      <div class="rb-wrap">
        <div class="rb-imgtext">
          <div class="rb-imgtext__media">
            <img src="/images/kryo-ganzkoerper-kit.webp" alt="Kryo-Equipment im Rubedo Spa — Handschuhe, Socken und Mundschutz auf burgunderfarbener Robe" width="800" height="600" loading="lazy" />
          </div>
          <div class="rb-imgtext__body">
            <span class="rb-eyebrow">Was passiert in der Kryo-Suite</span>
            <h2>Drei Minuten in einer Ein-Personen-Kabine.</h2>
            <p>Die Kryo-Suite ist eine Ein-Personen-Kabine, in der die Lufttemperatur kontrolliert auf etwa minus 110 °C abgesenkt wird. Du betrittst die Kabine in Wellness-Kleidung — Handschuhe, Socken und Mundschutz stellen wir — bewegst dich darin behutsam und stehst nach drei Minuten wieder im Raum. Im Anschluss aktivieren wir mit einer kurzen Bewegungssequenz deinen Kreislauf.</p>
            <p>Viele Gäste beschreiben das Gefühl danach als „kalt-warmes Wachsein". Manche nutzen Kryo vor sportlichen Belastungen für die Aktivierung, andere danach für die Regeneration, wieder andere als Reset in stressigen Wochen.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- WHEN GUESTS CHOOSE / WHEN NOT -->
    <section class="rb-block-duo rb-section--cream">
      <div class="rb-wrap">
        <div class="rb-duo">
          <div class="rb-duo__panel rb-duo__panel--check">
            <h3>Wann Gäste die Anwendung wählen</h3>
            <ul>
              <li>Vor und nach sportlichen Einheiten — als Beitrag zur empfundenen Erholung.</li>
              <li>Als bewusster Wachimpuls in Phasen mit langen Bildschirm-Tagen.</li>
              <li>Als Bestandteil einer Wellness-Routine — beispielsweise einmal pro Woche kombiniert mit einer Massage in der <a href="/inner-source/rubedo-suite/">Rubedo Suite</a>.</li>
              <li>Im Rahmen einer <a href="/dna-skin-intelligence/">DNA-Skin-Routine</a> — als zusätzlicher Vitalitäts-Impuls neben der Pflege.</li>
            </ul>
          </div>
          <div class="rb-duo__panel rb-duo__panel--cross">
            <h3>Wann Kryo nicht für dich geeignet ist</h3>
            <ul>
              <li>Unbehandelter Bluthochdruck oder schwere Herz-Kreislauf-Erkrankungen.</li>
              <li>Schwere Erkrankungen der Atemwege.</li>
              <li>Schwangerschaft.</li>
              <li>Offene Wunden, akute Hauterkrankungen oder Kälteallergien.</li>
              <li>Künstliche Herzklappen, bestimmte Schrittmacher und Implantate.</li>
            </ul>
          </div>
        </div>
        <p style="margin: 32px auto 0; max-width: 720px; text-align:center; font-size: 14px; color: var(--rb-ink-500); line-height: 1.65;">Vor deiner ersten Anwendung erhältst du einen Anamnese-Bogen. Wir besprechen mit dir gemeinsam, ob die Anwendung für dich passt — und im Zweifel verweisen wir an deine Hausärztin oder deinen Hausarzt.</p>
      </div>
    </section>

    <!-- PRICING -->
    <section id="preise" class="rb-block-pricing">
      <div class="rb-wrap">
        <div class="rb-pricing__head"><span class="rb-eyebrow">Konditionen</span><h2>Preise &amp; Karten.</h2></div>
        <div class="rb-pricing-tables">
          <div class="rb-pricing-table">
            <h3>Kryo-Suite — Ganzkörper</h3>
            <p class="rb-pricing-table__caption">15-Min-Termin · 3 Min in der Kabine</p>
            <ul class="rb-pricing-rows">
              <li><span>Einzelanwendung</span><span class="rb-pricing-rows__price">50 €</span></li>
              <li class="is-highlight"><span>4er-Testpaket <span class="rb-pricing-rows__badge">empfohlen</span></span><span class="rb-pricing-rows__price">160 €</span></li>
              <li><span>5er-Karte</span><span class="rb-pricing-rows__price">230 €</span></li>
              <li><span>10er-Karte</span><span class="rb-pricing-rows__price">450 €</span></li>
            </ul>
            <p class="rb-pricing-table__caption" style="margin-top: 16px; font-size: 12px; color: var(--rb-ink-500);">Das 4er-Testpaket ist einmalig pro Person buchbar.</p>
          </div>
          <div class="rb-pricing-table">
            <h3>Kryo-Lokal — gezielt</h3>
            <p class="rb-pricing-table__caption">15 Min · einzelne Körperzone</p>
            <ul class="rb-pricing-rows">
              <li><span>Einzelanwendung</span><span class="rb-pricing-rows__price">36 €</span></li>
              <li><span>5er-Karte</span><span class="rb-pricing-rows__price">165 €</span></li>
              <li><span>10er-Karte</span><span class="rb-pricing-rows__price">320 €</span></li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="rb-block-faq">
      <div class="rb-wrap">
        <div class="rb-faq__head">
          <div><span class="rb-eyebrow">FAQ · Ganzkörper-Kryo</span><h2>Häufige Fragen.</h2></div>
          <p>Drei Minuten klingen kurz — und werfen erfahrungsgemäß die meisten Fragen vorher auf.</p>
        </div>
        <ul class="rb-faq-list">
          <li><details class="rb-faq-item" open><summary>Tut die Kälte weh?</summary><div class="rb-faq-item__body">Nein. Die Kälte ist trocken und unangenehmer in der Vorstellung als in der Erfahrung. Die meisten Gäste sind nach den drei Minuten überrascht, wie kurz die Anwendung gefühlt war.</div></details></li>
          <li><details class="rb-faq-item"><summary>Was ziehe ich an?</summary><div class="rb-faq-item__body">Wellness-Unterwäsche oder Sportbekleidung. Handschuhe, Socken und Mundschutz stellen wir.</div></details></li>
          <li><details class="rb-faq-item"><summary>Wie schnell merke ich etwas?</summary><div class="rb-faq-item__body">Die meisten Gäste berichten unmittelbar nach der Anwendung von einem klaren, energetischen Empfinden. Manche merken stärkere Effekte erst nach drei bis vier Anwendungen — daher der Sinn des 4er-Testpakets.</div></details></li>
          <li><details class="rb-faq-item"><summary>Kann ich Kryo mit anderen Behandlungen kombinieren?</summary><div class="rb-faq-item__body">Ja. Beliebte Kombinationen sind Kryo + <a href="/kryo-vital/koerperformung/">Druckwellen-Anwendung</a> oder Kryo + Massage in der <a href="/inner-source/rubedo-suite/">Rubedo Suite</a>.</div></details></li>
        </ul>
      </div>
    </section>

    <!-- DISCLAIMER -->
    <section class="rb-block-disclaimer">
      <div class="rb-wrap rb-wrap--narrow">
        <div class="rb-disclaimer">
          <div class="rb-disclaimer__icon"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"><circle cx="12" cy="12" r="9"/><path d="M12 8v5M12 16v.01"/></svg></div>
          <div>
            <h3>Hinweis zur Wirkung</h3>
            <p>Die Kryotherapie wird im Rubedo Spa als Wellness-Anwendung angeboten. Wir machen keine medizinischen Heilversprechen. Empfindungen wie „erfrischend" oder „belebend" sind subjektive Wahrnehmungen, die von Gästen geschildert werden.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="rb-block-cta">
      <div class="rb-wrap">
        <div class="rb-cta-band">
          <div class="rb-cta-band__body">
            <span class="rb-eyebrow">Reservierung</span>
            <h3>Erlebe deinen ersten Kältereiz.</h3>
            <p>Mit dem 4er-Testpaket für 160 € — einmalig pro Person, ideal um zu spüren, wie dein Körper reagiert.</p>
          </div>
          <div class="rb-cta-band__action"><a class="rb-btn--ghost-light" href="/termin-buchen/?intent=kryo-suite">Termin buchen →</a></div>
        </div>
      </div>
    </section>

  </article>
</BaseLayout>
