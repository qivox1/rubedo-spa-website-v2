---
import BaseLayout from '@/layouts/BaseLayout.astro';

const title = 'Kontakt & Anfahrt — Rubedo Spa Minden';
const description = 'Marienstraße 58, 32427 Minden. Mo–Fr 09:00–19:00. Telefon 0571 78343423 — info@rubedo-spa.de.';
---

<BaseLayout
  title={title}
  description={description}
>

  <article class="rb-page" data-page='kontakt'>
    <section class="rb-block-hero rb-block-hero--centered">
        <div class="rb-wrap rb-block-hero__inner">
          <div>
            <span class="rb-block-hero__eyebrow">Studio · Minden</span>
            <h1>Im Studio. Oder per Videocall.</h1>
            <p class="rb-block-hero__subline" style="margin-left:auto;margin-right:auto;">Persönliche Beratung, Termine vor Ort und kostenfreie 15-Minuten-Erstgespräche per Video.</p>
          </div>
        </div>
      </section>

      <section class="rb-block-contact">
        <div class="rb-wrap">
          <div class="rb-contact">
            <div>
              <span class="rb-eyebrow">Standort & Kontakt</span>
              <h2>Marienstraße 58 · 32427 Minden.</h2>
              <p>Direkt im Herzen der Minder Innenstadt — Parkmöglichkeiten in Gehweite, der Bahnhof Minden zu Fuß in 12 Minuten erreichbar.</p>
              <ul class="rb-contact__list">
                <li><strong>Adresse</strong><span>Rubedo Spa, Marienstraße 58, 32427 Minden</span></li>
                <li><strong>Telefon</strong><span><a href="tel:+4957178343423">0571 78343423</a></span></li>
                <li><strong>E-Mail</strong><span><a href="/cdn-cgi/l/email-protection#9ff2f8dfedeafdfafbf0b2eceffeb1fbfa"><span class="__cf_email__" data-cfemail="9df0faddefe8fff8f9f2b0eeedfcb3f9f8">[email&#160;protected]</span></a></span></li>
                <li><strong>Mo–Fr</strong><span>09:00 — 19:00 Uhr</span></li>
                <li><strong>Sa</strong><span>10:00 — 16:00 Uhr · nach Vereinbarung</span></li>
                <li><strong>So</strong><span>geschlossen</span></li>
              </ul>
            </div>
            <div class="rb-contact__map">
              <span class="rb-contact__pin"></span>
              <span class="rb-contact__caption">Marienstraße 58 · Minden</span>
            </div>
          </div>
        </div>
      </section>

      <section class="rb-block-cta">
        <div class="rb-wrap">
          <div class="rb-cta-band">
            <div class="rb-cta-band__body">
              <span class="rb-eyebrow">Termin anfragen</span>
              <h3>Persönlich. Telefonisch. Per E-Mail. Oder online.</h3>
              <p>Wir melden uns innerhalb von 24 Stunden zurück — siezend, persönlich, ohne automatisierte Antwort.</p>
            </div>
            <div class="rb-cta-band__action"><a class="rb-btn--ghost-light" href="/termin-buchen/">Termin buchen →</a></div>
          </div>
        </div>
      </section>

    </article>

    <!-- ============================================================
         PAGE 9 · MAGAZIN — Übersicht / Kategorie-Seite
         URL: /magazin/
         ============================================================ -->
  </article>

</BaseLayout>
