---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { site } from '@/lib/site';

const title = 'Atemarbeit Minden — neurosomatisches Atem-Ritual';
const description = 'Neurosomatische Atemarbeit, Mindfulness, NLP- und Hypnose-Methoden im Wellness-Kontext. Inner Source Atem-Ritual im Rubedo Spa Minden.';
const heroImage = '/images/atem-ritual-hero.webp';
const url = `${site.url}/inner-source/atem-ritual/`;

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  '@id': `${url}#service`,
  serviceType: 'Atem & Inner Body Rituals',
  name: 'Atem & Inner Body Rituals — geführte 60-Minuten-Sitzung',
  description: 'Geführte 60-Minuten-Sitzung mit kurzen, klar strukturierten Atem-Sequenzen, Mindfulness-Elementen und Methoden aus NLP- und Hypnose-Coaching im Wellness-Kontext.',
  url,
  image: `${site.url}${heroImage}`,
  category: 'Wellness',
  provider: { '@id': `${site.url}/#localbusiness` },
  areaServed: { '@type': 'City', name: 'Minden' },
};

const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Start', item: `${site.url}/` },
    { '@type': 'ListItem', position: 2, name: 'Inner Source', item: `${site.url}/inner-source/` },
    { '@type': 'ListItem', position: 3, name: 'Atem-Ritual', item: url },
  ],
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    { '@type': 'Question', name: 'Muss ich „spirituell" sein, um die Atemarbeit zu nutzen?', acceptedAnswer: { '@type': 'Answer', text: 'Nein. Wir arbeiten ruhig, klar und unprätentiös. Du musst nichts glauben — du musst nur eine Stunde Aufmerksamkeit mitbringen.' } },
    { '@type': 'Question', name: 'Ist Atemarbeit eine Therapie?', acceptedAnswer: { '@type': 'Answer', text: 'Nein. Inner Source ist Wellness, keine Therapie. Wenn du an einer akuten psychischen Belastung leidest, gehörst du in die Hände einer Psychotherapeutin oder eines Arztes.' } },
    { '@type': 'Question', name: 'Wie unterscheidet sich das von einer Meditations-App?', acceptedAnswer: { '@type': 'Answer', text: 'Apps geben dir Tools an die Hand, die du allein anwendest. Wir arbeiten in einer geführten Sitzung mit dir — du erlebst innerhalb einer Stunde, wie dein eigenes System unter Aufmerksamkeit reagiert.' } },
    { '@type': 'Question', name: 'Wie oft kann ich das nutzen?', acceptedAnswer: { '@type': 'Answer', text: 'Manche Gäste kommen einmal und nehmen Mikro-Praktiken mit; andere bauen das Ritual als wöchentliche oder monatliche Pause in ihren Alltag ein. Wir besprechen den passenden Rhythmus im Erstgespräch.' } },
  ],
};
---

<BaseLayout
  title={title}
  description={description}
  heroImage={heroImage}
  schemaExtras={[serviceSchema, breadcrumb, faqSchema]}
>
  <article class="rb-page" data-page="atem-ritual">

    <!-- HERO -->
    <section class="rb-block-hero rb-block-hero--photo">
      <div class="rb-block-hero__photo">
        <img src="/images/atem-ritual-hero.webp" alt="Atem-Ritual im Rubedo Spa Minden — Klientin in stiller Atemübung, eine Hand auf Brust, eine auf Bauch, vor warmer Cremefassade mit Burgund-Vorhang" width="1600" height="914" fetchpriority="high" />
        <div class="rb-wrap">
          <div class="rb-block-hero__copy">
            <span class="rb-block-hero__eyebrow">Inner Source · Atem &amp; Inner Body</span>
            <h1>Eine Stunde geführte Aufmerksamkeit.</h1>
            <p class="rb-block-hero__subline">Neurosomatische Atemarbeit, Mindfulness und Mind-Methoden im Wellness-Kontext — als 60-Minuten-Sitzung mit Monica Galletti.</p>
            <div class="rb-block-hero__cta">
              <a href="/termin-buchen/#intent=atem" class="rb-btn rb-btn--primary rb-btn--lg">Atem-Erstgespräch</a>
              <a href="#methoden" class="rb-btn rb-btn--ghost">Methoden ansehen</a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- WAS PASSIERT -->
    <section class="rb-block-imgtext rb-section--paper">
      <div class="rb-wrap">
        <div class="rb-imgtext rb-imgtext--reverse">
          <div class="rb-imgtext__media">
            <img src="/images/inner-source-content-atem.webp" alt="Atem-Profil — Hand auf Brustkorb in burgunder Robe" width="800" height="600" loading="lazy" />
          </div>
          <div class="rb-imgtext__body">
            <span class="rb-eyebrow">Was du in einer Sitzung erlebst</span>
            <h2>Geführte Aufmerksamkeit, klar strukturiert.</h2>
            <p>Wir beginnen ruhig — eine kurze Einordnung deines aktuellen Zustands, ein paar offene Fragen, dann die erste Atem-Sequenz. Im Verlauf der 60 Minuten wechseln wir zwischen kurzen, klar strukturierten Atemphasen, Mindfulness-Elementen und — wo es passt — geführten Mind-Sequenzen aus dem NLP- und Hypnose-Repertoire im Wellness-Kontext.</p>
            <p>Ziel ist <strong>nicht</strong>, dir eine neue Technik beizubringen, die du täglich üben sollst. Ziel ist, dass du innerhalb dieser Stunde erlebst, wie sich dein eigenes System unter geführter Aufmerksamkeit verändert — und welche kurzen Mikro-Praktiken dir im Alltag tatsächlich nützen.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- METHODS -->
    <section id="methoden" class="rb-section rb-section--cream">
      <div class="rb-wrap">
        <div class="rb-block-cards__head">
          <div><span class="rb-eyebrow">Methoden</span><h2>Vier Werkzeuge, kombiniert.</h2></div>
        </div>
        <div class="rb-cards rb-cards--four">
          <article class="rb-tcard">
            <div class="rb-tcard__media rb-tcard__media--ayur"><svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M12 3c0 4-3 4-3 8s3 4 3 8"/><path d="M16 6c0 3-2 3-2 6s2 3 2 6"/></svg></div>
            <div class="rb-tcard__body">
              <h3 class="rb-tcard__title">Neurosomatische Atemarbeit</h3>
              <p class="rb-tcard__text">Strukturierte Atem-Sequenzen, die das vegetative Nervensystem ansprechen und in der Sitzung erfahrbar machen, wie sich der eigene Körperzustand binnen Minuten verändert.</p>
            </div>
          </article>
          <article class="rb-tcard">
            <div class="rb-tcard__media rb-tcard__media--stone"><svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><circle cx="12" cy="12" r="9"/><circle cx="12" cy="12" r="3"/></svg></div>
            <div class="rb-tcard__body">
              <h3 class="rb-tcard__title">Mindfulness</h3>
              <p class="rb-tcard__text">Klassische Aufmerksamkeits-Praxis — wir arbeiten mit kurzen, alltagstauglichen Übungen, nicht mit langen Sitzungen, die du erst lernen müsstest.</p>
            </div>
          </article>
          <article class="rb-tcard">
            <div class="rb-tcard__media rb-tcard__media--bambu"><svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M4 14c4-4 8-4 12 0"/><path d="M8 18c2-2 4-2 6 0"/><circle cx="11" cy="9" r="1.4"/></svg></div>
            <div class="rb-tcard__body">
              <h3 class="rb-tcard__title">NLP im Wellness-Kontext</h3>
              <p class="rb-tcard__text">Mind-Methoden aus dem NLP-Coaching — eingesetzt zur Aufmerksamkeits-Lenkung, nicht zur Therapie. Monica ist NLP-Master.</p>
            </div>
          </article>
          <article class="rb-tcard">
            <div class="rb-tcard__media rb-tcard__media--bali"><svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M3 12c4 6 14 6 18 0"/><path d="M3 12c4-6 14-6 18 0"/></svg></div>
            <div class="rb-tcard__body">
              <h3 class="rb-tcard__title">Hypnose im Wellness-Kontext</h3>
              <p class="rb-tcard__text">Geführte Tiefenentspannung — HWG-konform, ohne Heilanspruch. Eingesetzt, wo Aufmerksamkeit und Ruhe sich gegenseitig verstärken sollen.</p>
            </div>
          </article>
        </div>
      </div>
    </section>

    <!-- WHEN IT FITS / NOT -->
    <section class="rb-block-duo rb-section--paper">
      <div class="rb-wrap">
        <div class="rb-duo">
          <div class="rb-duo__panel rb-duo__panel--check">
            <h3>Wann Atem-Ritual besonders sinnvoll ist</h3>
            <ul>
              <li>Wenn du seit Wochen das Gefühl hast, „nicht runterzukommen".</li>
              <li>Wenn du eine bewusste Pause vor einem wichtigen Lebensabschnitt suchst.</li>
              <li>Wenn du die Wirkung deiner <a href="/dna-skin-intelligence/">DNA-Skin-Routine</a> vertiefen willst — Hautpflege ist immer auch Pflege des Nervensystems.</li>
              <li>Wenn du <a href="/kryo-vital/">Kryo Vital</a> nutzt und dem Körper einen ruhigen Gegenpol geben möchtest.</li>
              <li>Vor oder nach einer Massage in der <a href="/inner-source/rubedo-suite/">Rubedo Suite</a> — als Verstärker.</li>
            </ul>
          </div>
          <div class="rb-duo__panel rb-duo__panel--cross">
            <h3>Was Atem-Ritual nicht ist</h3>
            <ul>
              <li>Keine Psychotherapie und kein Ersatz für eine.</li>
              <li>Keine medizinische Atemtherapie und keine Behandlung von Atemwegserkrankungen.</li>
              <li>Kein Coaching im klassischen Sinn — wir arbeiten in der Sitzung, nicht in einem Lern-Plan.</li>
              <li>Bei akuten psychischen Belastungen oder Panikneigung verweisen wir an Fachstellen.</li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- FORMAT & CONDITIONS -->
    <section class="rb-block-pricing">
      <div class="rb-wrap">
        <div class="rb-pricing__head"><span class="rb-eyebrow">Format &amp; Konditionen</span><h2>Eine Sitzung, sechzig Minuten.</h2></div>
        <div class="rb-pricing-tables">
          <div class="rb-pricing-table">
            <h3>Atem-Ritual · 60 Minuten</h3>
            <p class="rb-pricing-table__caption">Einzelsitzung mit Monica Galletti</p>
            <ul class="rb-pricing-rows">
              <li><span>Erstgespräch (Videocall, 30 Min)</span><span class="rb-pricing-rows__price">kostenfrei</span></li>
              <li class="is-highlight"><span>60-Min-Sitzung im Studio <span class="rb-pricing-rows__badge">empfohlen für Einstieg</span></span><span class="rb-pricing-rows__price">auf Anfrage</span></li>
            </ul>
            <p class="rb-pricing-table__caption" style="margin-top: 16px; font-size: 12px; color: var(--rb-ink-500);">Im 30-Minuten-Erstgespräch klären wir Anliegen und Konditionen für die folgenden Sitzungen — keine Verkaufsgespräche, keine Pakete.</p>
          </div>
          <div class="rb-pricing-table">
            <h3>Kombi-Optionen</h3>
            <p class="rb-pricing-table__caption">Atem-Ritual als Verstärker zu anderen Anwendungen</p>
            <ul class="rb-pricing-rows">
              <li><span>+ Massage in der <a href="/inner-source/rubedo-suite/">Rubedo Suite</a></span><span class="rb-pricing-rows__price">auf Anfrage</span></li>
              <li><span>+ <a href="/kryo-vital/ganzkoerper/">Ganzkörper-Kryo</a> (Reset-Format)</span><span class="rb-pricing-rows__price">auf Anfrage</span></li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- DISCLAIMER -->
    <section class="rb-block-disclaimer">
      <div class="rb-wrap rb-wrap--narrow">
        <div class="rb-disclaimer">
          <div class="rb-disclaimer__icon"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"><circle cx="12" cy="12" r="9"/><path d="M12 8v5M12 16v.01"/></svg></div>
          <div>
            <h3>Hinweis zur Wirkung</h3>
            <p>Inner Source ist Wellness, keine Therapie. Wir arbeiten mit Menschen, die im Alltag ihren Boden suchen und finden wollen — nicht mit Diagnosen. Bei akuten psychischen Belastungen oder medizinischen Fragestellungen verweisen wir an Fachstellen oder Ärztinnen und Ärzte.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="rb-block-faq">
      <div class="rb-wrap">
        <div class="rb-faq__head">
          <div><span class="rb-eyebrow">FAQ · Atem-Ritual</span><h2>Häufige Fragen.</h2></div>
          <p>Du musst nichts „glauben" — du musst nur eine Stunde Aufmerksamkeit mitbringen.</p>
        </div>
        <ul class="rb-faq-list">
          <li><details class="rb-faq-item" open><summary>Muss ich „spirituell" sein, um die Atemarbeit zu nutzen?</summary><div class="rb-faq-item__body">Nein. Wir arbeiten ruhig, klar und unprätentiös. Du musst nichts glauben — du musst nur eine Stunde Aufmerksamkeit mitbringen.</div></details></li>
          <li><details class="rb-faq-item"><summary>Ist Atemarbeit eine Therapie?</summary><div class="rb-faq-item__body">Nein. Inner Source ist Wellness, keine Therapie. Wenn du an einer akuten psychischen Belastung leidest, gehörst du in die Hände einer Psychotherapeutin oder eines Arztes.</div></details></li>
          <li><details class="rb-faq-item"><summary>Wie unterscheidet sich das von einer Meditations-App?</summary><div class="rb-faq-item__body">Apps geben dir Tools an die Hand, die du allein anwendest. Wir arbeiten in einer geführten Sitzung mit dir — du erlebst innerhalb einer Stunde, wie dein eigenes System unter Aufmerksamkeit reagiert.</div></details></li>
          <li><details class="rb-faq-item"><summary>Wie oft kann ich das nutzen?</summary><div class="rb-faq-item__body">Manche Gäste kommen einmal und nehmen Mikro-Praktiken mit; andere bauen das Ritual als wöchentliche oder monatliche Pause in ihren Alltag ein. Wir besprechen den passenden Rhythmus im Erstgespräch.</div></details></li>
        </ul>
      </div>
    </section>

    <section class="rb-block-cta-whisper">
      <div class="rb-wrap">
        <aside class="rb-cta-whisper" aria-label="Kostenfreies 15-Minuten-Erstgespräch">
          <span class="rb-cta-whisper__eyebrow">15-Min-Videoberatung</span>
          <h3>Bereit, deinen Atem neu zu entdecken?</h3>
          <p>Atemarbeit beginnt mit einem Gespräch. Im kurzen Videocall mit Monica klären wir, ob das Atem-Ritual gerade der richtige Schritt für dich ist.</p>
          <a class="rb-cta-whisper__link" href="/termin-buchen/">Erstgespräch mit Monica buchen</a>
          <span class="rb-cta-whisper__meta">Kostenfrei · 15 Minuten · Online via Videocall</span>
        </aside>
      </div>
    </section>

    <!-- CTA -->
    <section class="rb-block-cta">
      <div class="rb-wrap">
        <div class="rb-cta-band">
          <div class="rb-cta-band__body">
            <span class="rb-eyebrow">Erstgespräch</span>
            <h3>Lerne die Methode in 30 Minuten kennen.</h3>
            <p>Kostenfreier Videocall. Wir besprechen, was du suchst, und ich erkläre dir, wie eine Sitzung abläuft.</p>
          </div>
          <div class="rb-cta-band__action"><a class="rb-btn--ghost-light" href="/termin-buchen/#intent=atem-erstgespraech">Erstgespräch sichern →</a></div>
        </div>
      </div>
    </section>

  </article>
</BaseLayout>
