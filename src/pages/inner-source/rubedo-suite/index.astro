---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { site } from '@/lib/site';

const title = 'Rubedo Suite — Massage-Rituale · Rubedo Spa Minden';
const description = 'Abhyanga, Hot Stone, Hot Bambu und Balinesische Deep Massage in der exklusiven Rubedo Suite — vier klassische Massage-Rituale im Rubedo Spa Minden bei Monica Galletti.';
const heroImage = '/images/rubedo-suite-hero.webp';
const url = `${site.url}/inner-source/rubedo-suite/`;

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  '@id': `${url}#service`,
  serviceType: 'Massage-Rituale',
  name: 'Rubedo Suite — Massage-Rituale',
  description: 'Vier klassische Massage-Rituale (Abhyanga, Hot Stone, Hot Bambu, Balinesische Deep Massage), durchgeführt in einer eigenen ruhigen Suite — als Einzel- oder Paar-Erlebnis.',
  url,
  image: `${site.url}${heroImage}`,
  category: 'Wellness',
  provider: { '@id': `${site.url}/#localbusiness` },
  areaServed: { '@type': 'City', name: 'Minden' },
  offers: [
    { '@type': 'Offer', name: 'Abhyanga (80 Min)', price: '175', priceCurrency: 'EUR' },
    { '@type': 'Offer', name: 'Hot Stone (80 Min)', price: '175', priceCurrency: 'EUR' },
    { '@type': 'Offer', name: 'Hot Bambu (80 Min)', price: '175', priceCurrency: 'EUR' },
    { '@type': 'Offer', name: 'Balinesische Deep Massage (50 Min)', price: '145', priceCurrency: 'EUR' },
  ],
};

const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Start', item: `${site.url}/` },
    { '@type': 'ListItem', position: 2, name: 'Inner Source', item: `${site.url}/inner-source/` },
    { '@type': 'ListItem', position: 3, name: 'Rubedo Suite', item: url },
  ],
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    { '@type': 'Question', name: 'Wie wähle ich die richtige Massage?', acceptedAnswer: { '@type': 'Answer', text: 'Wenn du dich neu orientierst: Abhyanga ist die ruhigste Wahl, Balinesische Deep Massage die kraftvollste. Hot Stone und Hot Bambu liegen dazwischen. Wir beraten dich gerne im Aufnahme-Gespräch.' } },
    { '@type': 'Question', name: 'Kann ich die Massage mit Inner-Source-Atemarbeit kombinieren?', acceptedAnswer: { '@type': 'Answer', text: 'Ja. Auf Wunsch beginnen wir die Sitzung mit einer fünfminütigen Atem-Sequenz, die deine Wahrnehmung für die folgende Anwendung öffnet.' } },
  ],
};
---

<BaseLayout
  title={title}
  description={description}
  heroImage={heroImage}
  schemaExtras={[serviceSchema, breadcrumb, faqSchema]}
>
  <article class="rb-page" data-page="rubedo-suite">

    <!-- HERO -->
    <section class="rb-block-hero rb-block-hero--photo">
      <div class="rb-block-hero__photo">
        <img src="/images/rubedo-suite-hero.webp" alt="Rubedo Suite im Rubedo Spa Minden — exklusive Massage-Suite mit warmem Licht und ruhiger Atmosphäre" width="1600" height="900" fetchpriority="high" />
        <div class="rb-wrap">
          <div class="rb-block-hero__copy">
            <span class="rb-block-hero__eyebrow">Inner Source · Rubedo Suite</span>
            <h1>Rituale für Körper, Geist und Atem.</h1>
            <p class="rb-block-hero__subline">Vier klassische Massage-Anwendungen — durchgeführt in einer ruhigen, exklusiven Suite.</p>
            <div class="rb-block-hero__cta">
              <a href="/termin-buchen/?intent=suite" class="rb-btn rb-btn--primary rb-btn--lg">Suite reservieren</a>
              <a href="#rituale" class="rb-btn rb-btn--ghost">Vier Rituale</a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- WHAT MAKES IT SPECIAL -->
    <section class="rb-block-imgtext rb-section--paper">
      <div class="rb-wrap">
        <div class="rb-imgtext">
          <div class="rb-imgtext__media">
            <img src="/images/rubedo-suite-hot-stone.webp" alt="Heiße Basaltsteine auf Energiepunkten — Hot-Stone-Anwendung in der Rubedo Suite" width="800" height="600" loading="lazy" />
          </div>
          <div class="rb-imgtext__body">
            <span class="rb-eyebrow">Was die Rubedo Suite besonders macht</span>
            <h2>Eine eigene Suite, keine offene Massage-Zone.</h2>
            <ul>
              <li>Eine eigene Suite — keine offene Massage-Zone.</li>
              <li>Eine ruhige, klare Atmosphäre statt zu vieler Reize.</li>
              <li>Eine Empfangs-Sequenz mit Atem und Aufmerksamkeit zu Beginn.</li>
              <li>Eine ruhige Ausstiegs-Phase mit Wasser und Zeit für ein kurzes Nachhören.</li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- FOUR RITUALS -->
    <section id="rituale" class="rb-section rb-section--cream">
      <div class="rb-wrap">
        <div class="rb-block-cards__head">
          <div><span class="rb-eyebrow">Vier klassische Rituale</span><h2>Abhyanga · Hot Stone · Hot Bambu · Balinesisch.</h2></div>
        </div>
        <div class="rb-cards rb-cards--four">
          <article class="rb-tcard">
            <div class="rb-tcard__media rb-tcard__media--ayur"><svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M12 2C8 7 8 12 12 17c4-5 4-10 0-15z"/><path d="M12 17v5"/></svg></div>
            <div class="rb-tcard__body">
              <div class="rb-tcard__meta"><span>80 Min</span><span>Ayurveda</span></div>
              <h3 class="rb-tcard__title">Abhyanga</h3>
              <p class="rb-tcard__text">Eine der traditionellsten Anwendungen aus dem indischen Ayurveda. Mit warmem, hochwertig ausgewähltem Öl wird der Körper in einem ruhigen Rhythmus über Bahnen und Gelenke geführt — die Kopfhaut wird mit einbezogen. Ein Ritual, das viele Gäste als „Heimat-Gefühl im eigenen Körper" beschreiben.</p>
              <div class="rb-tcard__foot"><span class="rb-tcard__price">175 €</span><a href="/termin-buchen/?intent=abhyanga" class="rb-tcard__cta">Buchen</a></div>
            </div>
          </article>
          <article class="rb-tcard">
            <div class="rb-tcard__media rb-tcard__media--stone rb-tcard__media--photo"><img src="/images/rubedo-suite-hot-stone.webp" alt="Heiße Basaltsteine auf Energiepunkten — Hot-Stone-Behandlung" width="600" height="400" loading="lazy" /></div>
            <div class="rb-tcard__body">
              <div class="rb-tcard__meta"><span>80 Min</span><span>Wärme</span></div>
              <h3 class="rb-tcard__title">Hot Stone</h3>
              <p class="rb-tcard__text">Heiße Basaltsteine werden auf Energiepunkten platziert und in der Massage-Sequenz selbst eingesetzt. Die Wärme erleichtert das Lösen von Verspannungswahrnehmungen und führt in eine tiefe, ruhige Wahrnehmungs-Ebene.</p>
              <div class="rb-tcard__foot"><span class="rb-tcard__price">175 €</span><a href="/termin-buchen/?intent=hot-stone" class="rb-tcard__cta">Buchen</a></div>
            </div>
          </article>
          <article class="rb-tcard">
            <div class="rb-tcard__media rb-tcard__media--bambu"><svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M5 3v18M9 3v18M13 3v18M17 3v18"/></svg></div>
            <div class="rb-tcard__body">
              <div class="rb-tcard__meta"><span>80 Min</span><span>Rhythmisch</span></div>
              <h3 class="rb-tcard__title">Hot Bambu</h3>
              <p class="rb-tcard__text">Beheizte Bambusstäbe in unterschiedlichen Größen werden in fließenden Bewegungen eingesetzt. Eine kraftvolle, klare Anwendung, die Muskel- und Bindegewebe in einem rhythmischen Rahmen anspricht.</p>
              <div class="rb-tcard__foot"><span class="rb-tcard__price">175 €</span><a href="/termin-buchen/?intent=hot-bambu" class="rb-tcard__cta">Buchen</a></div>
            </div>
          </article>
          <article class="rb-tcard">
            <div class="rb-tcard__media rb-tcard__media--bali"><svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M4 12c4 8 12 8 16 0M4 12c4-8 12-8 16 0"/></svg></div>
            <div class="rb-tcard__body">
              <div class="rb-tcard__meta"><span>50 Min</span><span>Deep</span></div>
              <h3 class="rb-tcard__title">Balinesische Deep</h3>
              <p class="rb-tcard__text">Eine kraftvolle, rhythmisch-tiefe Massage aus der traditionellen indonesischen Praxis. Beliebt bei Gästen, die nach einem klar spürbaren, energetischen Bodywork suchen.</p>
              <div class="rb-tcard__foot"><span class="rb-tcard__price">145 €</span><a href="/termin-buchen/?intent=balinese" class="rb-tcard__cta">Buchen</a></div>
            </div>
          </article>
        </div>
        <p style="margin: 28px auto 0; max-width: 720px; text-align:center; font-size: 13px; color: var(--rb-ink-500);">Preise verstehen sich pro Person. Paar-Erlebnisse mit zwei Behandelnden gestalten wir auf Wunsch — sprich uns gerne an.</p>
      </div>
    </section>

    <!-- COUPLE BOOKING -->
    <section class="rb-block-prose rb-section--paper">
      <div class="rb-wrap rb-prose">
        <span class="rb-eyebrow">Wenn du paarweise buchst</span>
        <h2>Zwei Menschen, zwei Behandelnde, ein Raum.</h2>
        <p>Die Rubedo Suite ist als Wellness-Erlebnis für eine Person oder für zwei Personen gleichzeitig konzipiert. Wenn du mit einer Begleitung kommen möchtest, sprich uns gerne an — wir gestalten ein parallel laufendes Ritual mit zwei Behandelnden.</p>
      </div>
    </section>

    <!-- FAQ -->
    <section class="rb-block-faq">
      <div class="rb-wrap">
        <div class="rb-faq__head">
          <div><span class="rb-eyebrow">FAQ · Rubedo Suite</span><h2>Häufige Fragen.</h2></div>
          <p>Wenn du dich neu orientierst, beraten wir dich gerne im Aufnahme-Gespräch.</p>
        </div>
        <ul class="rb-faq-list">
          <li><details class="rb-faq-item" open><summary>Wie wähle ich die richtige Massage?</summary><div class="rb-faq-item__body">Wenn du dich neu orientierst: Abhyanga ist die ruhigste Wahl, Balinesische Deep Massage die kraftvollste. Hot Stone und Hot Bambu liegen dazwischen. Wir beraten dich gerne im Aufnahme-Gespräch.</div></details></li>
          <li><details class="rb-faq-item"><summary>Kann ich die Massage mit Inner-Source-Atemarbeit kombinieren?</summary><div class="rb-faq-item__body">Ja. Auf Wunsch beginnen wir die Sitzung mit einer fünfminütigen <a href="/inner-source/atem-ritual/">Atem-Sequenz</a>, die deine Wahrnehmung für die folgende Anwendung öffnet.</div></details></li>
        </ul>
      </div>
    </section>

    <!-- CTA -->
    <section class="rb-block-cta">
      <div class="rb-wrap">
        <div class="rb-cta-band">
          <div class="rb-cta-band__body">
            <span class="rb-eyebrow">Reservierung</span>
            <h3>Reserviere deine Suite.</h3>
            <p>Als Einzel- oder Paar-Erlebnis. Wir gestalten ein parallel laufendes Ritual mit zwei Behandelnden auf Wunsch.</p>
          </div>
          <div class="rb-cta-band__action"><a class="rb-btn--ghost-light" href="/termin-buchen/?intent=suite">Termin buchen →</a></div>
        </div>
      </div>
    </section>

  </article>
</BaseLayout>
