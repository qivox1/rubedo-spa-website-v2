---
import BaseLayout from '@/layouts/BaseLayout.astro';
import MagazinTeaser from '@/components/MagazinTeaser.astro';
import { site } from '@/lib/site';

const title = 'Massage & Atemarbeit Minden — Inner Source im Rubedo Spa';
const description = 'Abhyanga, Hot Stone, Hot Bambu, Balinesisch — kombiniert mit neurosomatischer Atemarbeit. Inner Source Rituals im Rubedo Spa Minden.';
const heroImage = '/images/inner-source-hero.webp';
const url = `${site.url}/inner-source/`;

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  '@id': `${url}#service`,
  name: 'Inner Source Rituals — Massage & Atemarbeit',
  serviceType: 'Wellness Service',
  description: 'Klassische Massage-Rituale (Abhyanga, Hot Stone, Hot Bambu, Balinesische Deep Massage) kombiniert mit neurosomatischer Atemarbeit, Mindfulness und NLP-Methoden im Wellness-Kontext.',
  provider: { '@id': `${site.url}/#localbusiness` },
  areaServed: [
    { '@type': 'City', name: 'Minden' },
    { '@type': 'AdministrativeArea', name: 'Ostwestfalen-Lippe' },
  ],
  url,
  image: `${site.url}${heroImage}`,
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  '@id': `${url}#faq`,
  mainEntity: [
    { '@type': 'Question', name: 'Muss ich „spirituell" sein, um Inner Source zu nutzen?', acceptedAnswer: { '@type': 'Answer', text: 'Nein. Wir arbeiten ruhig, klar und unprätentiös. Du musst nichts glauben — du musst nur eine Stunde Aufmerksamkeit mitbringen.' } },
    { '@type': 'Question', name: 'Wie unterscheidet sich das von einer normalen Massage?', acceptedAnswer: { '@type': 'Answer', text: 'Eine normale Massage ist Körper-Arbeit. Inner Source verbindet Körper und Wahrnehmung. Schon der Einstieg unterscheidet sich — wir beginnen jede Sitzung mit einer kurzen Aufmerksamkeits-Übung.' } },
    { '@type': 'Question', name: 'Kann ich nur die Atem-Arbeit buchen?', acceptedAnswer: { '@type': 'Answer', text: 'Ja, ab Frühsommer 2026 als eigenständiges 60-Minuten-Format. Sprich uns gerne im Erstgespräch an.' } },
  ],
};
---

<BaseLayout
  title={title}
  description={description}
  heroImage={heroImage}
  schemaExtras={[serviceSchema, faqSchema]}
>

  <article class="rb-page" data-page='inner-source'>
    <section class="rb-block-hero rb-block-hero--photo">
        <div class="rb-block-hero__photo">
          <img src="/images/inner-source-hero.webp" alt="Inner Source Rituale im Rubedo Spa Minden — Hände in burgunder Robe halten dampfende Schale" width="1600" height="900" fetchpriority="high" />
          <div class="rb-wrap">
            <div class="rb-block-hero__copy">
              <span class="rb-block-hero__eyebrow">Säule 03 · Balance</span>
              <h1>Atem, Berührung und Stille als bewusste Tiefenarbeit.</h1>
              <p class="rb-block-hero__subline">Die leiseste der drei Säulen — und für viele Gäste die transformierendste.</p>
              <div class="rb-block-hero__cta">
                <a href="/inner-source/rubedo-suite/" class="rb-btn rb-btn--primary rb-btn--lg">Rubedo Suite ansehen</a>
                <a href="/inner-source/atem-ritual/" class="rb-btn rb-btn--ghost">Atem-Ritual</a>
              </div>
            </div>
          </div>
        </div>
      </section>

      <section class="rb-block-imgtext rb-section--paper">
        <div class="rb-wrap">
          <div class="rb-imgtext">
            <div class="rb-imgtext__media">
              <img src="/images/inner-source-content-atem.webp" alt="Atem-Profil — Hand auf Brustkorb in burgunder Robe" width="800" height="600" loading="lazy" />
            </div>
            <div class="rb-imgtext__body">
              <span class="rb-eyebrow">Warum Inner Source</span>
              <h2>Wenn keine weitere Methode hilft, sondern erst die richtige Anwendung der vorhandenen.</h2>
              <p>Inner Source ist die Säule, in der wir genau diesen Übergang gestalten — die Verbindung von Berührung, Atem und Wahrnehmung. Die meisten Gäste betreten Rubedo wegen einer konkreten Anwendung. Sie verlassen es oft mit einer neuen Aufmerksamkeit für ihren eigenen Atem.</p>
              <p>Diese Säule ruht auf zwei Beinen: einer ruhigen, ritualisierten <strong>Berührungs-Praxis</strong> (Massage und Bodywork) und einer modernen <strong>Atem- und Mind-Arbeit</strong>, die seit 2019 ein zentraler Schwerpunkt von Monica Galletti ist.</p>
            </div>
          </div>
        </div>
      </section>

      <!-- Vier Rituale -->
      <section class="rb-section rb-section--cream">
        <div class="rb-wrap">
          <div class="rb-block-cards__head">
            <div><span class="rb-eyebrow">Rubedo Suite</span><h2>Vier klassische Massage-Rituale.</h2></div>
          </div>
          <div class="rb-cards rb-cards--four">
            <article class="rb-tcard">
              <div class="rb-tcard__media rb-tcard__media--ayur"><svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M12 2C8 7 8 12 12 17c4-5 4-10 0-15z"/><path d="M12 17v5"/></svg></div>
              <div class="rb-tcard__body">
                <div class="rb-tcard__meta"><span>80 Min</span><span>Ayurveda</span></div>
                <h3 class="rb-tcard__title">Abhyanga</h3>
                <p class="rb-tcard__text">Ayurvedische Ganzkörperölmassage mit warmem Öl — über Bahnen und Gelenke geführt, Kopfhaut wird einbezogen.</p>
                <div class="rb-tcard__foot"><span class="rb-tcard__price">175 €</span><a href="/inner-source/rubedo-suite/" class="rb-tcard__cta">Zur Rubedo Suite</a></div>
              </div>
            </article>
            <article class="rb-tcard">
              <div class="rb-tcard__media rb-tcard__media--stone rb-tcard__media--photo"><img src="/images/rubedo-suite-hot-stone.webp" alt="Heiße Basaltsteine auf Energiepunkten — Hot-Stone-Behandlung" width="600" height="400" loading="lazy" /><svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><circle cx="8" cy="14" r="4"/><circle cx="16" cy="9" r="3"/><circle cx="14" cy="17" r="2"/></svg></div>
              <div class="rb-tcard__body">
                <div class="rb-tcard__meta"><span>80 Min</span><span>Wärme</span></div>
                <h3 class="rb-tcard__title">Hot Stone</h3>
                <p class="rb-tcard__text">Heiße Basaltsteine auf Energiepunkten — die Wärme erleichtert das Lösen von Verspannungswahrnehmungen.</p>
                <div class="rb-tcard__foot"><span class="rb-tcard__price">175 €</span><a href="/inner-source/rubedo-suite/" class="rb-tcard__cta">Zur Rubedo Suite</a></div>
              </div>
            </article>
            <article class="rb-tcard">
              <div class="rb-tcard__media rb-tcard__media--bambu"><svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M5 3v18M9 3v18M13 3v18M17 3v18"/></svg></div>
              <div class="rb-tcard__body">
                <div class="rb-tcard__meta"><span>80 Min</span><span>Rhythmisch</span></div>
                <h3 class="rb-tcard__title">Hot Bambu</h3>
                <p class="rb-tcard__text">Beheizte Bambusstäbe in unterschiedlichen Größen, in fließenden Bewegungen — kraftvoll, klar, anregend.</p>
                <div class="rb-tcard__foot"><span class="rb-tcard__price">175 €</span><a href="/inner-source/rubedo-suite/" class="rb-tcard__cta">Zur Rubedo Suite</a></div>
              </div>
            </article>
            <article class="rb-tcard">
              <div class="rb-tcard__media rb-tcard__media--bali"><svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M4 12c4 8 12 8 16 0M4 12c4-8 12-8 16 0"/></svg></div>
              <div class="rb-tcard__body">
                <div class="rb-tcard__meta"><span>50 Min</span><span>Deep</span></div>
                <h3 class="rb-tcard__title">Balinesische Deep</h3>
                <p class="rb-tcard__text">Kraftvoll-rhythmisches Bodywork aus der traditionellen indonesischen Praxis. Klar spürbar, energetisch.</p>
                <div class="rb-tcard__foot"><span class="rb-tcard__price">145 €</span><a href="/inner-source/rubedo-suite/" class="rb-tcard__cta">Zur Rubedo Suite</a></div>
              </div>
            </article>
          </div>
        </div>
      </section>

      <section class="rb-block-cta-whisper">
        <div class="rb-wrap">
          <aside class="rb-cta-whisper" aria-label="Kostenfreies 15-Minuten-Erstgespräch">
            <span class="rb-cta-whisper__eyebrow">15-Min-Videoberatung</span>
            <h3>Welches Ritual ist der richtige Anfang?</h3>
            <p>Atem, Massage oder das volle Suite-Erlebnis — im kurzen Videocall mit Monica finden wir gemeinsam heraus, was für dich gerade Sinn macht.</p>
            <a class="rb-cta-whisper__link" href="/termin-buchen/">Erstgespräch mit Monica buchen</a>
            <span class="rb-cta-whisper__meta">Kostenfrei · 15 Minuten · Online via Videocall</span>
          </aside>
        </div>
      </section>

      <!-- Atem-Block -->
      <section class="rb-block-prose rb-section--paper">
        <div class="rb-wrap rb-prose">
          <span class="rb-eyebrow">Atem & Inner Body Rituals</span>
          <h2>Eine Stunde geführte Aufmerksamkeit.</h2>
          <p>Seit 2019 ist neurosomatische Atemarbeit ein fester Bestandteil von Monicas Praxis. Im Inner-Source-Ritual kombinieren wir kurze, klar strukturierte Atem-Sequenzen mit Methoden aus Mindfulness, NLP-Coaching im Wellness-Kontext und Hypnose für Tiefenentspannung.</p>
          <p>Ziel ist nicht, dir eine neue Technik beizubringen, die du täglich üben sollst. Ziel ist, dass du innerhalb einer Sitzung erlebst, wie sich dein eigenes System unter geführter Aufmerksamkeit verändert — und welche kurzen Mikro-Praktiken dir im Alltag tatsächlich nützen.</p>

          <h3>Wann Inner Source besonders sinnvoll ist</h3>
          <ul>
            <li>Wenn du seit Wochen das Gefühl hast, „nicht runterzukommen".</li>
            <li>Wenn du eine bewusste Pause vor einem wichtigen Lebensabschnitt suchst.</li>
            <li>Wenn du die Wirkung deiner <a href="/dna-skin-intelligence/">DNA-Skin-Routine</a> vertiefen willst — denn Hautpflege ist immer auch Pflege des Nervensystems.</li>
            <li>Wenn du <a href="/kryo-vital/">Kryo Vital</a> nutzt und dem Körper einen ruhigen Gegenpol geben möchtest.</li>
          </ul>
          <p style="margin-top: 24px;"><a href="/inner-source/atem-ritual/" class="rb-link-arrow"><strong>Atem-Ritual im Detail ansehen →</strong></a></p>
        </div>
      </section>

      <section class="rb-block-quote">
        <div class="rb-block-quote__inner">
          <blockquote>Inner Source ist Wellness, keine Therapie. Wir arbeiten mit Menschen, die im Alltag ihren Boden suchen und finden wollen — nicht mit Diagnosen.</blockquote>
          <cite>Monica Galletti</cite>
        </div>
      </section>

      <section class="rb-block-faq">
        <div class="rb-wrap">
          <div class="rb-faq__head">
            <div><span class="rb-eyebrow">FAQ · Inner Source</span><h2>Häufige Fragen.</h2></div>
            <p>Du musst nichts „glauben" — du musst nur eine Stunde Aufmerksamkeit mitbringen.</p>
          </div>
          <ul class="rb-faq-list">
            <li><details class="rb-faq-item" open><summary>Muss ich „spirituell" sein, um Inner Source zu nutzen?</summary><div class="rb-faq-item__body">Nein. Wir arbeiten ruhig, klar und unprätentiös. Du musst nichts glauben — du musst nur eine Stunde Aufmerksamkeit mitbringen.</div></details></li>
            <li><details class="rb-faq-item"><summary>Wie unterscheidet sich das von einer normalen Massage?</summary><div class="rb-faq-item__body">Eine normale Massage ist Körper-Arbeit. Inner Source verbindet Körper und Wahrnehmung. Schon der Einstieg unterscheidet sich — wir beginnen jede Sitzung mit einer kurzen Aufmerksamkeits-Übung.</div></details></li>
            <li><details class="rb-faq-item"><summary>Kann ich nur die Atem-Arbeit buchen?</summary><div class="rb-faq-item__body">Ja, ab Frühsommer 2026 als eigenständiges 60-Minuten-Format. Sprich uns gerne im Erstgespräch an.</div></details></li>
          </ul>
        </div>
      </section>

      <section class="rb-block-cross-pillars">
        <div class="rb-wrap">
          <div class="rb-cross-pillars">
            <span class="rb-cross-pillars__eyebrow">Weiter ergründen</span>
            <ul class="rb-cross-pillars__list">
              <li><a href="/dna-skin-intelligence/">DNA Skin Intelligence</a></li>
              <li><a href="/kryo-vital/">Kryo Vital</a></li>
            </ul>
          </div>
        </div>
      </section>

      <section class="rb-block-cta">
        <div class="rb-wrap">
          <div class="rb-cta-band">
            <div class="rb-cta-band__body">
              <span class="rb-eyebrow">Reservierung</span>
              <h3>Buche dein erstes Ritual in der Rubedo Suite.</h3>
              <p>Als Einzel- oder Paar-Erlebnis. Wir gestalten ein parallel laufendes Ritual mit zwei Behandelnden auf Wunsch.</p>
            </div>
            <div class="rb-cta-band__action"><a class="rb-btn--ghost-light" href="/termin-buchen/">Suite reservieren →</a></div>
          </div>
        </div>
      </section>

    </article>

    <!-- ============================================================
         PAGE 6 · KÖRPERFORMUNG (Druckwellen + Wraps + Bandagen)
         URL: /kryo-vital/koerperformung/
         ============================================================ -->

    <MagazinTeaser
      tags={["inner-source", "atemarbeit", "abhyanga", "hot-stone", "massage", "drei-saeulen", "berührung"]}
      heading="Aus dem Inner-Source-Magazin"
      eyebrow="Vertiefen"
      intro="Atemarbeit, Massage-Rituale, Mind-Methoden — was Berührung und Stille im Nervensystem bewirken."
      variant="cream"
    />

  </article>

</BaseLayout>
