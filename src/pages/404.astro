---
import BaseLayout from '@/layouts/BaseLayout.astro';

const title = 'Seite nicht gefunden';
const description = 'Diese Seite existiert nicht oder wurde verschoben.';
---

<BaseLayout title={title} description={description} noindex>
  <section class="rb-section rb-section--paper">
    <div class="rb-wrap rb-wrap--narrow" style="text-align:center; padding: var(--rb-space-9) 0;">
      <span class="rb-eyebrow">404 · Nicht gefunden</span>
      <h1 class="rb-display" style="margin: 16px 0 24px;">Hier ist nichts.</h1>
      <p style="font-family: var(--rb-font-body); color: var(--rb-ink-700); line-height: var(--rb-leading-loose); max-width: 56ch; margin: 0 auto 32px;">
        Die Seite existiert nicht oder wurde verschoben. Vielleicht hilft dir einer der folgenden Wege weiter:
      </p>
      <div style="display: flex; gap: 16px; justify-content: center; flex-wrap: wrap;">
        <a href="/" class="rb-btn rb-btn--primary">Zur Startseite</a>
        <a href="/philosophie/" class="rb-btn rb-btn--ghost">Philosophie</a>
        <a href="/termin-buchen/" class="rb-btn rb-btn--ghost">Termin buchen</a>
      </div>
    </div>
  </section>
</BaseLayout>
