---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { site } from '@/lib/site';

const title = 'Longevity-Studio Minden — Rubedo Spa';
const description = 'Longevity-Studio in Minden — Rubedo Spa von Monica Galletti, CIDESCO Beauty Therapist und DNA-Skin-Expertin. Drei Säulen, ein System, ein Studio in der Marienstraße.';
const url = `${site.url}/longevity-studio-minden/`;

const aboutPageSchema = {
  '@context': 'https://schema.org',
  '@type': 'AboutPage',
  '@id': `${url}#aboutpage`,
  url,
  name: title,
  description,
  inLanguage: 'de-DE',
  isPartOf: { '@type': 'WebSite', '@id': `${site.url}/#website`, url: site.url, name: site.name },
  mainEntity: { '@id': `${site.url}/#localbusiness` },
  primaryImageOfPage: { '@type': 'ImageObject', url: `${site.url}/images/monica-portrait.webp` },
  breadcrumb: {
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Startseite', item: `${site.url}/` },
      { '@type': 'ListItem', position: 2, name: 'Longevity-Studio Minden', item: url },
    ],
  },
};
---

<BaseLayout
  title={title}
  description={description}
  schemaExtras={[aboutPageSchema]}
>

  <article class="rb-page" data-page="longevity-studio">

    <section class="rb-block-hero rb-block-hero--centered">
      <div class="rb-wrap rb-block-hero__inner">
        <div>
          <span class="rb-block-hero__eyebrow">Studio · Minden</span>
          <h1>Longevity-Studio Minden.</h1>
          <p class="rb-block-hero__subline" style="margin-left:auto;margin-right:auto;">
            Rubedo Spa ist kein klassisches Spa, sondern ein Longevity-Studio in der Marienstraße 58.
            Drei Säulen, eine Haltung — geführt von Monica Galletti.
          </p>
        </div>
      </div>
    </section>

    <section class="rb-section rb-section--paper">
      <div class="rb-wrap rb-wrap--narrow rb-prose">
        <span class="rb-eyebrow">Was ein Longevity-Studio ausmacht</span>
        <h2>Pflege, die langfristig denkt.</h2>
        <p>
          Longevity beschreibt einen Lebensstil und eine Pflege-Haltung, die auf
          Vorsorge, Regeneration und Selbstregulation setzen. In einem
          <strong>Longevity-Studio</strong> steht die langfristige Vitalität im Mittelpunkt —
          nicht das schnelle Ergebnis. Das ist der Unterschied zwischen einer Behandlung,
          die heute gut tut, und einer Routine, die in fünf Jahren noch wirkt.
        </p>
        <p>
          Im Rubedo Spa verbinden wir personalisierte Hautpflege auf DNA-Basis,
          kontrollierte Kälteanwendungen und neurosomatische Atemarbeit zu einem
          System, das auf den einzelnen Menschen zugeschnitten ist. Drei Säulen
          ergeben gemeinsam mehr als die Summe ihrer Teile.
        </p>

        <h3>Studio &amp; Mensch</h3>
        <p>
          Das Studio wird von <a href="/ueber-monica/" rel="author">Monica Galletti</a>
          geführt — CIDESCO Beauty Therapist, DNA Skin Expert (Beauty ID Switzerland),
          NLP Master und seit über zehn Jahren in der internationalen 5-Sterne-Spa-Praxis tätig.
          Unsere Arbeit basiert auf zertifizierter Ausbildung, sorgfältiger Recherche und
          jahrelanger Erfahrung mit Gästen, die ihre Pflege ernst nehmen — und Zeit dafür
          mitbringen wollen.
        </p>

        <h3>Drei Säulen, ein System</h3>
        <p>Wir arbeiten ausschließlich entlang dieser drei Säulen — keine Behandlungen, die nicht eingebettet sind.</p>
        <ul>
          <li><a href="/dna-skin-intelligence/"><strong>DNA Skin Intelligence</strong></a> — personalisierte Hautpflege auf Basis von 20 Beauty-Genen.</li>
          <li><a href="/kryo-vital/"><strong>Kryo Vital</strong></a> — Ganzkörper-Kryotherapie, Kryo-Lokal, Druckwellen, Bandagen, Wraps.</li>
          <li><a href="/inner-source/"><strong>Inner Source Rituals</strong></a> — Massage-Rituale in der Rubedo Suite und neurosomatische Atemarbeit.</li>
        </ul>

        <h3>Mission</h3>
        <p>
          Wir machen sichtbare und spürbare Pflege zugänglich — ohne Heilversprechen,
          ohne Verkaufsdruck. „Smart Beauty for Conscious Humans" beschreibt unsere
          Haltung: präzise, persönlich, präsent.
        </p>

        <h3>Werte</h3>
        <ul>
          <li><strong>Personalisierung statt Standardisierung</strong> — jeder Mensch ist einzigartig.</li>
          <li><strong>Wissenschaft trifft Ritual</strong> — moderne Skin Science und klassische Tradition.</li>
          <li><strong>Klare Sprache</strong> — wir machen keine Heilversprechen.</li>
          <li><strong>Beständigkeit</strong> — wir bauen Beziehungen, keine Saison-Verkäufe.</li>
        </ul>

        <h3>Standort</h3>
        <p>
          Rubedo Spa, Marienstraße 58, 32427 Minden — Mo bis Fr von 09:00 bis 19:00 Uhr.
          Erreichbar unter <a href={`tel:${site.contact.phoneE164}`}>{site.contact.phoneDisplay}</a>
          oder <a href={`mailto:${site.contact.email}`}>{site.contact.email}</a>.
          Anfahrt und Parkmöglichkeiten beschreiben wir auf der
          <a href="/kontakt/">Kontakt-Seite</a>.
        </p>

        <h3>Mehr erfahren</h3>
        <p>
          Eine ausführliche Vita von Monica Galletti — Werdegang, Zertifizierungen,
          Methodik — findest du auf der Seite <a href="/ueber-monica/" rel="author">Über
          Monica</a>. Die Philosophie des Studios beschreibt die <a href="/philosophie/">Philosophie-Seite</a>.
        </p>
      </div>
    </section>

    <section class="rb-block-cta">
      <div class="rb-wrap">
        <div class="rb-cta-band">
          <div class="rb-cta-band__body">
            <span class="rb-eyebrow">Kennenlernen</span>
            <h3>15 Minuten Videocall — kostenfrei.</h3>
            <p>Wir besprechen, was du suchst, und Monica erklärt, welche Säule für dich passt.</p>
          </div>
          <div class="rb-cta-band__action"><a class="rb-btn--ghost-light" href="/termin-buchen/?intent=erstgespraech">Erstgespräch buchen →</a></div>
        </div>
      </div>
    </section>

  </article>

</BaseLayout>
